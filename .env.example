# =============================================================================
# Astro Rocket / Monto IA — Variáveis de Ambiente (exemplo)
# =============================================================================
# Copie este arquivo para `.env` (gitignored) e preencha com valores reais.
# Variáveis com prefixo PUBLIC_ são embutidas no bundle do cliente — NUNCA
# coloque segredos (API keys, tokens) com esse prefixo.

# -----------------------------------------------------------------------------
# Obrigatório
# -----------------------------------------------------------------------------

# URL de produção do site (sitemap, canonical URLs, OG images)
SITE_URL=http://localhost:4321

# -----------------------------------------------------------------------------
# Analytics / Tag Manager (opcional)
# -----------------------------------------------------------------------------

# Google Tag Manager — recomendado: centralize GA4, Meta Pixel, Ads etc. no GTM
# em vez de configurar cada um diretamente no código.
# PUBLIC_GTM_ID=GTM-XXXXXXX

# Google Analytics 4 — só usar SEM GTM (Analytics.astro dá prioridade ao GTM
# quando ambos estão definidos).
# PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# -----------------------------------------------------------------------------
# Monto API — Formulário de Contato
# -----------------------------------------------------------------------------

# URL base da Monto API (sem barra final)
PUBLIC_CONTACT_API_URL=https://api.monto.ia.br

# Token de autenticação da API (prefixo mt_).
# É PUBLIC_ porque o formulário de contato faz o POST direto do browser.
# O token é restrito por domínio (Origin header validado na API) — risco aceitável.
# Para dev local: o token não aceita localhost; o envio retornará 401 (esperado).
PUBLIC_CONTACT_API_TOKEN=mt_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Resend — envio de e-mail transacional (formulário de contato interno)
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=naoresponda@yourdomain.com

# -----------------------------------------------------------------------------
# Cloudflare Turnstile — verificação antispam nos formulários
# Obter em: dash.cloudflare.com → Turnstile → Add site
# PUBLIC_ = chave do site (cliente). Sem prefixo = chave secreta (somente servidor).
# -----------------------------------------------------------------------------
PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAxxxxxxxxxxxxxxxxxxx
TURNSTILE_SECRET_KEY=0x4AAAAAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Verificação de motores de busca (opcional)
# -----------------------------------------------------------------------------

# GOOGLE_SITE_VERIFICATION=your-verification-code
# BING_SITE_VERIFICATION=your-verification-code

# -----------------------------------------------------------------------------
# Consentimento / Privacidade (opcional)
# -----------------------------------------------------------------------------

# Ativa o banner de consentimento de cookies (Consent Mode v2)
# PUBLIC_CONSENT_ENABLED=true

# Link para a política de privacidade (exibido no banner de consentimento)
PUBLIC_PRIVACY_POLICY_URL=http://localhost:4321/politica-de-privacidade

# -----------------------------------------------------------------------------
# Mapas (opcional)
# -----------------------------------------------------------------------------

# PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-key
