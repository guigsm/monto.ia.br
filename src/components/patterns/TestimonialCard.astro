---
import Card from '@/components/ui/data-display/Card/Card.astro';
import type { NormalizedReview } from '@/lib/testimonials';

interface Props {
  review: NormalizedReview;
  locale?: string;
  /** 0, 1 ou 2 — mapeia para data-reveal-delay para stagger de animação */
  revealDelay?: 0 | 1 | 2;
}

const { review, locale = 'pt-br', revealDelay } = Astro.props;

const text = locale === 'en' ? review.textEn : review.text;
const starsLabel = locale === 'en'
  ? `${review.rating} out of 5 stars`
  : `${review.rating} de 5 estrelas`;
const googleTitle = locale === 'en' ? 'Google Review' : 'Avaliação no Google';

function initials(name: string) {
  return name.split(' ').slice(0, 2).map((n) => n[0]).join('').toUpperCase();
}

function formatDate(iso: string) {
  const date = new Date(iso);
  const lang = locale === 'en' ? 'en-US' : 'pt-BR';
  return date.toLocaleDateString(lang, { month: 'long', year: 'numeric' });
}
---

<Card
  variant="elevated"
  padding="lg"
  hover
  data-reveal
  data-reveal-delay={revealDelay !== undefined ? String(revealDelay) : undefined}
>
  <div class="flex flex-col h-full gap-4">
    <!-- Estrelas -->
    <div class="flex gap-1 text-brand-500" role="img" aria-label={starsLabel}>
      {[...Array(review.rating)].map(() => (
        <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20" aria-hidden="true">
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
        </svg>
      ))}
    </div>

    <!-- Texto do depoimento -->
    <blockquote class="flex-1 text-sm text-foreground-muted leading-relaxed">
      &ldquo;{text}&rdquo;
    </blockquote>

    <!-- Autor -->
    <div class="flex items-center gap-3 pt-4 border-t border-border">
      {review.author.avatarUrl ? (
        <img
          src={review.author.avatarUrl}
          alt={review.author.name}
          width="36"
          height="36"
          class="w-9 h-9 rounded-full object-cover shrink-0"
          loading="lazy"
        />
      ) : (
        <div class="w-9 h-9 rounded-full bg-gradient-to-br from-brand-500/30 to-brand-500/10 flex items-center justify-center text-brand-500 font-bold text-sm shrink-0">
          {initials(review.author.name)}
        </div>
      )}
      <div class="min-w-0 flex-1">
        <cite class="text-sm font-semibold text-foreground truncate not-italic block">
          {review.author.name}
        </cite>
        <p class="text-xs text-foreground-muted">{formatDate(review.publishedAt)}</p>
      </div>
      {review.platform === 'gbp' && (
        <div class="ml-auto shrink-0" title={googleTitle}>
          <svg class="w-4 h-4 text-foreground-muted" viewBox="0 0 24 24" aria-hidden="true">
            <path fill="currentColor" d="M12 11h8.533c.044.385.067.78.067 1.184 0 2.734-.98 5.047-2.687 6.6C16.32 20.272 14.307 21 12 21c-4.97 0-9-4.03-9-9s4.03-9 9-9c2.43 0 4.466.89 6.03 2.346L16.4 6.98A6.86 6.86 0 0 0 12 5.5C8.416 5.5 5.5 8.416 5.5 12S8.416 18.5 12 18.5c3.12 0 5.321-1.787 5.955-4.5H12V11z"/>
          </svg>
        </div>
      )}
    </div>
  </div>
</Card>
