---
import Input from '@/components/ui/form/Input/Input.astro';
import Textarea from '@/components/ui/form/Textarea/Textarea.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import { cn } from '@/lib/cn';
import { t } from '@/i18n';
import type { Locale } from '@/i18n';

interface Props {
  locale?: Locale;
  class?: string;
}

const { locale = 'pt-br', class: className } = Astro.props;

const apiUrl = '/api/contact';
const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY ?? '';

// Locale enviado para a API para que os labels do email sigam o idioma
const apiLocale = locale === 'en' ? 'en' : 'pt';

const labels = {
  name: t('contact.name', locale),
  email: t('contact.email', locale),
  message: t('contact.message', locale),
  messageHint: t('contact.messageHint', locale),
  send: t('contact.send', locale),
  sending: t('contact.sending', locale),
  success: t('contact.success', locale),
  error: t('contact.error', locale),
  nameValidation: t('contact.nameValidation', locale),
  emailValidation: t('contact.emailValidation', locale),
  messageValidation: t('contact.messageValidation', locale),
};
---

<form id="contact-form" class={cn('space-y-5', className)} novalidate>

  <!-- Nome completo — padrão exige pelo menos 2 palavras com ≥2 chars cada -->
  <Input
    label={labels.name}
    name="name"
    type="text"
    required
    minlength={5}
    autocomplete="name"
    pattern={"[A-Za-z\\u00C0-\\u024F]{2,}([ ][A-Za-z\\u00C0-\\u024F]{2,})+"}
    title={labels.nameValidation}
  />

  <Input
    label={labels.email}
    name="email"
    type="email"
    required
    autocomplete="email"
    title={labels.emailValidation}
  />

  <Textarea
    label={labels.message}
    name="message"
    required
    rows={5}
    minlength={20}
    maxlength={500}
    title={labels.messageValidation}
    hint={labels.messageHint}
  />

  <!-- Honeypot para spam -->
  <div class="hidden" aria-hidden="true">
    <input type="text" name="_honeypot" tabindex="-1" autocomplete="off" />
  </div>

  <!-- Cloudflare Turnstile — widget invisível, executado manualmente no submit -->
  <div
    id="cf-turnstile-widget"
    class="cf-turnstile"
    data-sitekey={turnstileSiteKey}
    data-execution="execute"
    data-appearance="invisible"
    data-callback="onTurnstileToken"
  ></div>

  <!-- Metadados para a API: locale (labels do email) e assunto identificador -->
  <input type="hidden" name="_locale" value={apiLocale} />
  <input type="hidden" name="subject" value={locale === 'en' ? 'Contact — monto.ia.br' : 'Contato — monto.ia.br'} />

  <div id="form-message" role="alert" aria-live="polite" class="hidden text-sm rounded-md px-4 py-3"></div>

  <div class="flex justify-center">
    <Button type="submit" id="submit-button" class="gap-2 w-full sm:w-auto">
      {labels.send}
      <Icon name="arrow-right" size="sm" />
    </Button>
  </div>
</form>

<script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

<script define:vars={{ apiUrl, labels }}>
  // Resolução da Promise do Turnstile — preenchida pelo callback global
  let _turnstileResolve = null;
  let _turnstileReject  = null;

  window.onTurnstileToken = (token) => {
    if (_turnstileResolve) { _turnstileResolve(token); _turnstileResolve = null; _turnstileReject = null; }
  };
  window.onTurnstileError = () => {
    if (_turnstileReject) { _turnstileReject(new Error('turnstile')); _turnstileResolve = null; _turnstileReject = null; }
  };

  function getTurnstileToken() {
    return new Promise((resolve, reject) => {
      _turnstileResolve = resolve;
      _turnstileReject  = reject;
      if (window.turnstile) {
        window.turnstile.execute('#cf-turnstile-widget');
      } else {
        // Turnstile não carregou (ex: dev sem chave) — envia sem token
        resolve('');
      }
    });
  }

  function initContactForm() {
    const form = /** @type {HTMLFormElement|null} */ (document.getElementById('contact-form'));
    const button = /** @type {HTMLButtonElement|null} */ (document.getElementById('submit-button'));
    const messageEl = document.getElementById('form-message');

    if (!form || !button || !messageEl) return;

    // Aplica mensagens de validação customizadas (idioma correto no tooltip nativo)
    form.querySelectorAll('[title][pattern], [title][type="email"], [title][required]').forEach((el) => {
      el.addEventListener('invalid', () => {
        /** @type {HTMLInputElement} */ (el).setCustomValidity(el.getAttribute('title') ?? '');
      });
      el.addEventListener('input', () => {
        /** @type {HTMLInputElement} */ (el).setCustomValidity('');
      });
    });

    function setMessage(text, isSuccess) {
      messageEl.textContent = text;
      if (isSuccess) {
        messageEl.className = 'text-sm rounded-md px-4 py-3 bg-success/10 text-success border border-success/20';
      } else {
        messageEl.className = 'text-sm rounded-md px-4 py-3 bg-destructive/10 text-destructive border border-destructive/20';
      }
      messageEl.classList.remove('hidden');
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Honeypot — bot preencheu o campo oculto
      if (/** @type {HTMLInputElement} */ (form.elements.namedItem('_honeypot'))?.value) return;

      // Dispara validação HTML5 nativa antes do fetch
      if (!form.checkValidity()) {
        form.reportValidity();
        return;
      }

      button.disabled = true;
      const originalText = button.textContent;
      button.textContent = labels.sending;
      messageEl.classList.add('hidden');

      try {
        // Dispara o Turnstile e aguarda o token (invisível para o usuário)
        const turnstileToken = await getTurnstileToken();

        const formData = new FormData(form);
        if (turnstileToken) formData.set('cf-turnstile-response', turnstileToken);

        const response = await fetch(apiUrl, {
          method: 'POST',
          body: formData,
        });

        const data = await response.json();

        if (data.success) {
          setMessage(labels.success, true);
          form.reset();
          // Reseta o widget para permitir novo envio
          if (window.turnstile) window.turnstile.reset('#cf-turnstile-widget');
        } else {
          setMessage(data.message || labels.error, false);
          if (window.turnstile) window.turnstile.reset('#cf-turnstile-widget');
        }
      } catch {
        setMessage(labels.error, false);
        if (window.turnstile) window.turnstile.reset('#cf-turnstile-widget');
      } finally {
        button.disabled = false;
        button.textContent = originalText;
      }
    });
  }

  initContactForm();
  document.addEventListener('astro:after-swap', initContactForm);
</script>
