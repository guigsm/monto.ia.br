---
import Button from '@/components/ui/form/Button/Button.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import { cn } from '@/lib/cn';
import { t } from '@/i18n';
import type { Locale } from '@/i18n';

interface Props {
  locale?: Locale;
  class?: string;
}

const { locale = 'pt-br', class: className } = Astro.props;

const apiUrl = '/api/contact';
const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY ?? '';
const isEn = locale === 'en';

const labels = {
  name:               t('contact.name',               locale),
  company:            t('contact.company',             locale),
  whatsapp:           t('contact.whatsapp',            locale),
  email:              t('contact.email',               locale),
  message:            t('contact.message',             locale),
  messageHint:        t('contact.messageHint',         locale),
  send:               t('contact.send',                locale),
  sending:            t('contact.sending',             locale),
  success:            t('contact.success',             locale),
  error:              t('contact.error',               locale),
  nameValidation:     t('contact.nameValidation',      locale),
  whatsappValidation: t('contact.whatsappValidation',  locale),
  emailValidation:    t('contact.emailValidation',     locale),
  messageValidation:  t('contact.messageValidation',   locale),
  searchCountry:      t('contact.searchCountry',       locale),
};
---

<form
  id="contact-form"
  class={cn('flex flex-col gap-3', className)}
  novalidate
  data-api-url={apiUrl}
  data-labels={JSON.stringify(labels)}
  data-locale={locale}
>

  <!-- Row 1: Nome | Empresa -->
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">

    <div class="cf-field">
      <label for="cf-name" class="cf-label">
        {labels.name}<span class="cf-req" aria-hidden="true"> *</span>
      </label>
      <div class="cf-ring">
        <input
          id="cf-name"
          name="name"
          type="text"
          class="cf-input"
          required
          minlength={5}
          autocomplete="name"
          pattern={"[A-Za-z\\u00C0-\\u024F]{2,}([ ][A-Za-z\\u00C0-\\u024F]{2,})+"}
          placeholder={isEn ? 'John Smith' : 'João Silva'}
        />
        <span class="cf-vi" aria-hidden="true"></span>
      </div>
    </div>

    <div class="cf-field">
      <label for="cf-company" class="cf-label">{labels.company}</label>
      <div class="cf-ring">
        <input
          id="cf-company"
          name="company"
          type="text"
          class="cf-input"
          autocomplete="organization"
          placeholder={isEn ? 'Your company (optional)' : 'Sua empresa (opcional)'}
        />
      </div>
    </div>

  </div>

  <!-- Row 2: WhatsApp | Email -->
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">

    <div class="cf-field">
      <label for="cf-phone" class="cf-label">
        {labels.whatsapp}<span class="cf-req" aria-hidden="true"> *</span>
      </label>
      <div class="cf-ring cf-ring-phone" id="cf-ring-phone">
        <input
          id="cf-phone"
          name="whatsapp"
          type="tel"
          class="cf-input"
          required
        />
        <span class="cf-vi" aria-hidden="true"></span>
      </div>
    </div>

    <div class="cf-field">
      <label for="cf-email" class="cf-label">
        {labels.email}<span class="cf-req" aria-hidden="true"> *</span>
      </label>
      <div class="cf-ring">
        <input
          id="cf-email"
          name="email"
          type="email"
          class="cf-input"
          required
          autocomplete="email"
          placeholder={isEn ? 'you@example.com' : 'voce@exemplo.com'}
        />
        <span class="cf-vi" aria-hidden="true"></span>
      </div>
    </div>

  </div>

  <!-- Mensagem (full width) -->
  <div class="cf-field">
    <label for="cf-message" class="cf-label">
      {labels.message}<span class="cf-req" aria-hidden="true"> *</span>
    </label>
    <div class="cf-ring">
      <textarea
        id="cf-message"
        name="message"
        class="cf-input cf-textarea"
        required
        minlength={20}
        maxlength={500}
      ></textarea>
      <span class="cf-vi cf-vi--textarea" aria-hidden="true"></span>
    </div>
    <p class="text-xs text-foreground-muted">
      {isEn ? 'Type between 20 and 500 characters. Now: ' : 'Digite entre 20 e 500 caracteres. Agora: '}<strong id="cf-char-count">(0)</strong>.
    </p>
  </div>

  <!-- Honeypot anti-spam -->
  <div class="hidden" aria-hidden="true">
    <input type="text" name="_honeypot" tabindex="-1" autocomplete="off" />
  </div>

  <!-- Cloudflare Turnstile â€” sÃ³ renderiza quando a site key estÃ¡ configurada -->
  {turnstileSiteKey && (
    <div
      id="cf-turnstile"
      class="cf-turnstile"
      data-sitekey={turnstileSiteKey}
      data-execution="execute"
      data-appearance="interaction-only"
      data-callback="onTurnstileToken"
      data-error-callback="onTurnstileError"
    ></div>
  )}

  <input type=”hidden” name=”subject” value={isEn ? 'Contact — monto.ia.br' : 'Contato — monto.ia.br'} />

  <div id="cf-status" role="alert" aria-live="polite" class="hidden text-sm rounded-md px-4 py-3"></div>

  <div class="flex justify-center pt-1">
    <Button type="submit" id="cf-submit" class="gap-2 w-full sm:w-auto">
      {labels.send}
      <Icon name="arrow-right" size="sm" />
    </Button>
  </div>

</form>

<!-- Turnstile SDK â€” sÃ³ carrega quando a site key estÃ¡ configurada -->
{turnstileSiteKey && (
  <>
    <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
    <script is:inline>
      window.onTurnstileToken = function(token) {
        if (window._cfResolve) {
          window._cfResolve(token);
          window._cfResolve = null;
          window._cfReject  = null;
        }
      };
      window.onTurnstileError = function() {
        if (window._cfReject) {
          window._cfReject(new Error('turnstile'));
          window._cfResolve = null;
          window._cfReject  = null;
        }
      };
    </script>
  </>
)}

<!-- Form logic â€” Vite-bundled (enables static import of intl-tel-input) -->
<script>
  import intlTelInput from 'intl-tel-input';

  let _iti = null;
  let _selectedCountry = 'br';    // tracks user's explicit country choice
  let _isRestoringCountry = false; // prevents countrychange loop when we call setSelectedCountry
  let _countryClickHandler = null; // ref kept for cleanup on re-init (astro:after-swap)

  // Per-country format map. Each entry has one or more templates ordered by maxDigits ascending.
  // applyMask() picks the first template whose maxDigits >= digit count; the last is the fallback.
  // placeholder is the example shown to the user â€” applyMask(example_digits) must produce it.
  const phoneFormats = {
    br: { templates: [
      { maxDigits: 10, mask: 'XX XXXX-XXXX',  placeholder: '11 1234-5678'  },
      { maxDigits: 11, mask: 'XX XXXXX-XXXX', placeholder: '11 12345-6789' },
    ]},
    us: { templates: [{ maxDigits: 10, mask: 'XXX-XXX-XXXX',    placeholder: '201-555-0123'  }] },
    ca: { templates: [{ maxDigits: 10, mask: 'XXX-XXX-XXXX',    placeholder: '506-555-0123'  }] },
    pt: { templates: [{ maxDigits:  9, mask: 'XXX XXX XXX',     placeholder: '912 345 678'   }] },
    es: { templates: [{ maxDigits:  9, mask: 'XXX XX XX XX',    placeholder: '612 34 56 78'  }] },
    gb: { templates: [{ maxDigits: 11, mask: 'XXXXX XXXXXX',    placeholder: '07700 900123'  }] },
    ar: { templates: [{ maxDigits: 10, mask: 'XX XXXX-XXXX',    placeholder: '11 2345-6789'  }] },
    mx: { templates: [{ maxDigits: 10, mask: 'XX XXXX XXXX',    placeholder: '55 1234 5678'  }] },
    de: { templates: [{ maxDigits: 11, mask: 'XXXX XXXXXXX',    placeholder: '0301 2345678'  }] },
    fr: { templates: [{ maxDigits: 10, mask: 'XX XX XX XX XX',  placeholder: '06 12 34 56 78'}] },
    it: { templates: [{ maxDigits: 10, mask: 'XXX XXX XXXX',    placeholder: '312 345 6789'  }] },
    cl: { templates: [{ maxDigits:  9, mask: 'X XXXX XXXX',     placeholder: '9 1234 5678'   }] },
    co: { templates: [{ maxDigits: 10, mask: 'XXX XXX XXXX',    placeholder: '312 345 6789'  }] },
    uy: { templates: [{ maxDigits:  9, mask: 'X XXX XXXX',      placeholder: '9 123 4567'    }] },  // actually varies
    pe: { templates: [{ maxDigits:  9, mask: 'XXX XXX XXX',     placeholder: '912 345 678'   }] },
    jp: { templates: [{ maxDigits: 11, mask: 'XXX-XXXX-XXXX',   placeholder: '090-1234-5678' }] },
    au: { templates: [{ maxDigits: 10, mask: 'XXXX XXX XXX',    placeholder: '0412 345 678'  }] },
    nz: { templates: [{ maxDigits: 10, mask: 'XXX XXX XXXX',    placeholder: '021 234 5678'  }] },
  };

  // Generic mask application â€” no country-specific IFs inside.
  // Picks the template whose maxDigits fits the current digit count.
  function applyMask(rawDigits, templates) {
    const tmpl = templates.find(t => rawDigits.length <= t.maxDigits) ?? templates.at(-1);
    const digits = rawDigits.slice(0, tmpl.maxDigits);
    let out = '';
    let di = 0;
    for (const ch of tmpl.mask) {
      if (ch === 'X') {
        if (di < digits.length) out += digits[di++];
        else break;
      } else if (di > 0) {
        out += ch; // separador sÃ³ apÃ³s ao menos um dÃ­gito
      }
    }
    return out.replace(/[\s\-]+$/, ''); // remove separadores finais pendentes
  }

  function applyRingState(ring, ok) {
    ring.classList.toggle('cf-error', !ok);
    ring.classList.toggle('cf-valid', ok);
    ring.closest('.cf-field')?.classList.toggle('cf-field--err', !ok);
  }

  function checkRing(ring, field) {
    if (!field.required && !field.value.trim()) {
      ring.classList.remove('cf-error', 'cf-valid');
      ring.closest('.cf-field')?.classList.remove('cf-field--err');
      return true;
    }
    const ok = field.checkValidity() && field.value.trim() !== '';
    applyRingState(ring, ok);
    return ok;
  }

  function checkPhoneRing() {
    const ring = document.getElementById('cf-ring-phone');
    if (!ring || !_iti) return true;
    const phoneInput = /** @type {HTMLInputElement|null} */ (ring.querySelector('input'));
    const hasValue = !!(phoneInput && phoneInput.value.trim().length > 3);
    const valid = hasValue && !!(_iti?.isValidNumber ? _iti.isValidNumber() : true);
    applyRingState(ring, valid);
    return valid;
  }

  function initPhone() {
    const phoneInput = /** @type {HTMLInputElement|null} */ (document.getElementById('cf-phone'));
    if (!phoneInput) return;

    if (_iti) { try { _iti.destroy(); } catch (_) {} _iti = null; }

    // Reset per-mount state
    _selectedCountry = 'br';
    _isRestoringCountry = false;

    const form   = document.getElementById('contact-form');
    const labels = JSON.parse(form?.dataset.labels || '{}');
    const locale = form?.dataset.locale || 'pt-br';

    _iti = intlTelInput(phoneInput, {
      initialCountry: 'br',
      separateDialCode: true,
      strictMode: false,
      countrySearch: true,
      formatAsYouType: false,     // we apply our own template-based mask
      countrySelectorMode: window.innerWidth < 768 ? 'FULLSCREEN' : 'DROPDOWN',
      dropdownParent: document.getElementById('cf-ring-phone'),  // ignored in FULLSCREEN mode
      matchDropdownWidth: true,
      countryNameLocale: locale === 'en' ? 'en' : 'pt-BR',
      uiTranslations: { searchPlaceholder: labels.searchCountry || 'Buscar país' },
      loadUtils: () => import('intl-tel-input/dist/js/utils.js'),
      // For countries in phoneFormats: use our example; otherwise fall back to library default.
      customPlaceholder: (libDefault, countryData) => {
        const fmt = phoneFormats[countryData?.iso2];
        return fmt ? fmt.templates.at(-1).placeholder : libDefault;
      },
    });

    // Returns the format for the selected country.
    // If the country is in phoneFormats, use our curated entry.
    // Otherwise auto-derive mask and maxDigits from the library's own placeholder â€”
    // this guarantees placeholder === applyMask(digits) for every country universally.
    function getFormat() {
      const iso2 = _iti?.getSelectedCountry?.()?.iso2;
      if (phoneFormats[iso2]) return phoneFormats[iso2];
      const ph = phoneInput.placeholder;
      if (!ph) return null;
      return { templates: [{
        maxDigits : (ph.match(/\d/g) ?? []).length,
        mask      : ph.replace(/\d/g, 'X'),
        placeholder: ph,
      }]};
    }

    function updateMaxLength() {
      const fmt = getFormat();
      if (fmt) phoneInput.maxLength = fmt.templates.at(-1).placeholder.length;
      else phoneInput.removeAttribute('maxlength');
    }

    // Block non-digit keystrokes before they reach the input value.
    phoneInput.addEventListener('keydown', (e) => {
      if (
        e.key.length > 1 || // control keys (Backspace, Delete, Tab, ArrowLeftâ€¦)
        e.ctrlKey || e.metaKey || // Ctrl/Cmd combos (copy, paste, select-all)
        /^\d$/.test(e.key)  // digit â€” allow
      ) return;
      e.preventDefault();
    });

    // On every input (including paste), strip non-digits and apply the country mask.
    phoneInput.addEventListener('input', () => {
      const rawDigits = phoneInput.value.replace(/\D/g, '');
      const fmt = getFormat();
      const masked = fmt ? applyMask(rawDigits, fmt.templates) : rawDigits;
      if (phoneInput.value !== masked) {
        phoneInput.value = masked;
      }
    });

    // Dynamically compute text-indent to clear the country button (width varies by dial code).
    // Also set border-radius as inline style so it beats any library CSS !important rule.
    function updatePhoneIndent() {
      const container = /** @type {HTMLElement|null} */ (document.querySelector('.cf-ring-phone .iti__country-container'));
      if (!container) return;
      phoneInput.style.textIndent = (container.offsetWidth + 5) + 'px';
      phoneInput.style.borderRadius = 'calc(0.5rem - 1.5px)';
      updateMaxLength();
    }
    requestAnimationFrame(updatePhoneIndent);

    // Placeholder (and therefore maxlength) is only set after utils.js finishes loading.
    if (_iti.promise) _iti.promise.then(updateMaxLength);

    // Track user-chosen country via clicks on dropdown items.
    // The selector is detached (iti--detached-country-selector), so listen on document capture phase
    // which fires before intl-tel-input closes the dropdown and before countrychange fires.
    if (_countryClickHandler) document.removeEventListener('click', _countryClickHandler, true);
    _countryClickHandler = (e) => {
      const li = /** @type {HTMLElement|null} */ (/** @type {HTMLElement} */ (e.target).closest('[data-iso2]'));
      if (li) _selectedCountry = li.dataset.iso2 ?? _selectedCountry;
    };
    document.addEventListener('click', _countryClickHandler, true);

    phoneInput.addEventListener('countrychange', () => {
      // Guard: we called setSelectedCountry() ourselves to undo an auto-switch â€” skip processing.
      if (_isRestoringCountry) { _isRestoringCountry = false; return; }

      const newIso2 = _iti?.getSelectedCountry?.()?.iso2;

      if (newIso2 === _selectedCountry) {
        // User-initiated change (dropdown click already updated _selectedCountry)
        phoneInput.value = '';
        requestAnimationFrame(updatePhoneIndent);
      } else {
        // Library auto-switched country (e.g. Canada â†’ USA via formatAsYouType).
        // Lock back to what the user explicitly chose.
        _isRestoringCountry = true;
        try { _iti.setSelectedCountry(_selectedCountry); } catch (_) { _isRestoringCountry = false; }
      }
    });
  }

  function initForm() {
    const form = /** @type {HTMLFormElement|null} */ (document.getElementById('contact-form'));
    if (!form) return;

    const apiUrl   = form.dataset.apiUrl || '/api/contact';
    const labels   = JSON.parse(form.dataset.labels || '{}');
    const button   = /** @type {HTMLButtonElement|null} */ (document.getElementById('cf-submit'));
    const statusEl = document.getElementById('cf-status');

    initPhone();

    // Live character counter for message textarea
    const textarea = /** @type {HTMLTextAreaElement|null} */ (document.getElementById('cf-message'));
    const charCount = document.getElementById('cf-char-count');
    if (textarea && charCount) {
      textarea.addEventListener('input', () => {
        charCount.textContent = `(${textarea.value.length})`;
      });
    }

    // Blur: validate if field has content or is already marked
    // Input: re-validate if already marked (update errorâ†’valid in real time)
    form.querySelectorAll('.cf-ring').forEach((ring) => {
      const field = /** @type {HTMLInputElement|HTMLTextAreaElement|null} */ (ring.querySelector('input, textarea'));
      if (!field) return;
      field.addEventListener('blur', () => {
        const marked = ring.classList.contains('cf-error') || ring.classList.contains('cf-valid');
        if (field.value.trim() || marked) {
          if (ring.id === 'cf-ring-phone') checkPhoneRing();
          else checkRing(ring, field);
        }
      });
      field.addEventListener('input', () => {
        const marked = ring.classList.contains('cf-error') || ring.classList.contains('cf-valid');
        if (marked) {
          if (ring.id === 'cf-ring-phone') checkPhoneRing();
          else checkRing(ring, field);
        }
      });
    });

    function setStatus(text, ok) {
      if (!statusEl) return;
      statusEl.textContent = text;
      statusEl.className = ok
        ? 'text-sm rounded-md px-4 py-3 bg-success/10 text-success border border-success/20'
        : 'text-sm rounded-md px-4 py-3 bg-destructive/10 text-destructive border border-destructive/20';
      statusEl.classList.remove('hidden');
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      if (/** @type {HTMLInputElement} */ (form.elements.namedItem('_honeypot'))?.value) return;

      // Validate all â€” show ! on every invalid field, focus the first one
      let allOk = true;
      let firstInvalid = null;
      form.querySelectorAll('.cf-ring').forEach((ring) => {
        const field = /** @type {HTMLInputElement|HTMLTextAreaElement|null} */ (ring.querySelector('input, textarea'));
        if (!field) return;
        const ok = ring.id === 'cf-ring-phone' ? checkPhoneRing() : checkRing(ring, field);
        if (!ok) {
          allOk = false;
          if (!firstInvalid) firstInvalid = field;
        }
      });
      if (!allOk) {
        firstInvalid?.focus();
        return;
      }

      if (button) button.disabled = true;
      const origLabel = button ? button.textContent : '';
      if (button) button.textContent = labels.sending || '…';
      statusEl?.classList.add('hidden');

      try {
        const token = await new Promise((resolve, reject) => {
          window._cfResolve = resolve;
          window._cfReject  = reject;
          if (window.turnstile) window.turnstile.execute('#cf-turnstile');
          else resolve('');
        });

        const fd = new FormData(form);

        if (_iti && _iti.getNumber) {
          const fullNum = _iti.getNumber();
          if (fullNum) fd.set('whatsapp', fullNum);
        }

        if (token) fd.set('cf-turnstile-response', String(token));

        const res  = await fetch(apiUrl, { method: 'POST', body: fd });
        const data = await res.json();

        if (data.success) {
          setStatus(labels.success, true);
          form.reset();
          try { if (_iti) _iti.setSelectedCountry('br'); } catch (_) {}
          form.querySelectorAll('.cf-ring').forEach(r => r.classList.remove('cf-error', 'cf-valid'));
          form.querySelectorAll('.cf-field').forEach(f => f.classList.remove('cf-field--err'));
          const cc = document.getElementById('cf-char-count');
          if (cc) cc.textContent = '(0)';
          if (window.turnstile) window.turnstile.reset('#cf-turnstile');
        } else {
          setStatus(data.message || labels.error, false);
          if (window.turnstile) window.turnstile.reset('#cf-turnstile');
        }
      } catch {
        setStatus(labels.error, false);
        if (window.turnstile) window.turnstile.reset('#cf-turnstile');
      } finally {
        if (button) { button.disabled = false; button.textContent = origLabel; }
      }
    });
  }

  initForm();
  document.addEventListener('astro:after-swap', initForm);
</script>

<style is:global>
  /* â”€â”€â”€ intl-tel-input base CSS (provides dropdown hide/show + flag sprite rules) â”€â”€â”€ */
  @import 'intl-tel-input/dist/css/intlTelInput-no-assets.css';

  /* â”€â”€â”€ Flag sprite path (override defaults; files copied to public/ for reliable serving) â”€â”€â”€ */
  :root {
    --iti-path-flags-1x: url('/flags.webp');
    --iti-path-flags-2x: url('/flags@2x.webp');
  }

  /* â”€â”€â”€ @property for animatable angle â”€â”€â”€ */
  @property --cf-spin {
    syntax: '<angle>';
    initial-value: 0deg;
    inherits: false;
  }

  /* â”€â”€â”€ Keyframes â”€â”€â”€ */
  @keyframes cf-border-run {
    to { --cf-spin: 360deg; }
  }
  @keyframes cf-border-pulse {
    0%, 100% {
      box-shadow: 0 0 0 0 color-mix(in oklch, var(--brand-500) 0%, transparent);
    }
    50% {
      box-shadow:
        0 0 0 3px color-mix(in oklch, var(--brand-500) 22%, transparent),
        0 0 12px color-mix(in oklch, var(--brand-500) 14%, transparent);
    }
  }

  /* â”€â”€â”€ Field container â”€â”€â”€ */
  .cf-field {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  /* â”€â”€â”€ Label â”€â”€â”€ */
  .cf-label {
    font-size: 0.875rem;
    font-weight: 500;
    line-height: 1;
    color: var(--foreground);
    transition: color 0.2s ease;
  }
  .cf-req {
    color: var(--brand-500);
    font-weight: 600;
  }

  /* Label turns brand-colored when its field has an error */
  .cf-field--err .cf-label {
    color: var(--brand-500);
  }

  /* â”€â”€â”€ Border ring wrapper â”€â”€â”€ */
  .cf-ring {
    position: relative;
    border-radius: 0.5rem;
    padding: 1.5px;
    background: color-mix(in oklch, var(--brand-500) 30%, transparent);
    transition: box-shadow 0.35s ease;
  }

  /* Focus state: spinning gradient border */
  .cf-ring:focus-within:not(.cf-error) {
    background: conic-gradient(
      from var(--cf-spin),
      transparent 55%,
      var(--brand-500) 75%,
      transparent 100%
    );
    animation: cf-border-run 1.8s linear infinite;
  }

  /* Error state: solid brand border + neon pulse + tinted background */
  .cf-ring.cf-error {
    background: var(--brand-500) !important;
    animation: cf-border-pulse 1.5s ease-in-out infinite !important;
  }
  .cf-ring.cf-error > input,
  .cf-ring.cf-error > textarea {
    background: color-mix(in oklch, var(--brand-500) 10%, var(--input-bg, var(--background))) !important;
  }
  .cf-ring-phone.cf-error .iti,
  .cf-ring-phone.cf-error .iti input[type=tel],
  .cf-ring-phone.cf-error .iti__selected-country {
    background: color-mix(in oklch, var(--brand-500) 10%, var(--input-bg, var(--background))) !important;
  }

  /* â”€â”€â”€ Validation icon â€” absolute in ring, zero layout impact â”€â”€â”€ */
  .cf-vi {
    position: absolute;
    right: 0.5rem;
    top: 50%;
    transform: translateY(-50%);
    font-size: 0.8125rem;
    font-weight: 900;
    line-height: 1;
    pointer-events: none;
    color: var(--brand-500);
    display: none;
    z-index: 2;
  }
  /* Textarea icon sits at top-right, not vertically centered */
  .cf-vi--textarea {
    top: 0.625rem;
    transform: none;
  }
  .cf-ring.cf-valid .cf-vi,
  .cf-ring.cf-error .cf-vi { display: block; }
  .cf-ring.cf-valid .cf-vi::before { content: '\2713'; }
  .cf-ring.cf-error .cf-vi::before { content: '\2715'; }

  /* â”€â”€â”€ Input / textarea inside the ring â”€â”€â”€ */
  .cf-ring > input,
  .cf-ring > textarea {
    display: block;
    width: 100%;
