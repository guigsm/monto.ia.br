  /* ── Layout flex: scroll area + settings row fixa no fundo ── */
  .mobile-menu-body {
    display: flex;
    flex-direction: column;
    max-height: calc(100svh - 4.5rem);
  }

  /* Área de scroll: social + nav */
  .mobile-menu-scroll {
    flex: 1;
    min-height: 0;
    overflow-y: auto;
    overscroll-behavior: contain;
    scrollbar-width: none;
  }
  .mobile-menu-scroll::-webkit-scrollbar {
    display: none;
  }

  /* ── Settings row: sempre visível no fundo, fora do scroll ── */
  .mobile-settings-row {
    flex-shrink: 0;
    border-top: 1px solid color-mix(in oklch, var(--color-border) 60%, transparent);
    padding-top: 0.5rem;
  }

  /* ── Grid de configurações: Modo | Cor | Idioma ── */
  .mobile-settings-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.25rem;
    padding: 0.5rem 0;
  }

  .mobile-settings-col {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.25rem;
  }

  .mobile-settings-label {
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-foreground-subtle);
  }

  /* Botões nas settings não quebram linha */
  .mobile-settings-row button {
    white-space: nowrap;
  }

  /* ── Dropdowns abrem para CIMA (sem clipping de overflow) ── */

  /* Modo (coluna esquerda): alinha à esquerda */
  .mobile-settings-col:first-child .ttg-panel {
    top: auto;
    bottom: calc(100% + 0.5rem);
    left: 0;
    right: auto;
    transform: none;
    margin-top: 0;
  }

  /* Cor (coluna central): color panel via CSS absolute, centralizado */
  .mobile-settings-col:nth-child(2) .mobile-color-panel {
    position: absolute;
    bottom: calc(100% + 0.5rem);
    left: 50%;
    transform: translateX(-50%);
    top: auto;
    z-index: 50; /* acima do rótulo IDIOMA e outros irmãos */
