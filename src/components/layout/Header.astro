---
/**
 * Header Component
 * Flexible navigation header with variant-based configuration
 */

import type { HTMLAttributes } from 'astro/types';
import { cn } from '@/lib/cn';
import { getNavItems, HOME_PATH, type NavItem as NavConfigItem } from '@/config/nav.config';
import { headerVariants, headerInnerVariants } from './header.variants';
import Button from '@/components/ui/form/Button/Button.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Logo from '@/components/ui/marketing/Logo/Logo.astro';
import ThemeModeDropdown from '@/components/layout/ThemeModeDropdown.astro';
import ThemeSelector from '@/components/layout/ThemeSelector.astro';
import ThemeSelectorDropdown from '@/components/layout/ThemeSelectorDropdown.astro';
import LanguageSwitcher from '@/components/layout/LanguageSwitcher.astro';
import Search from '@/components/layout/Search.astro';
import siteConfig from '@/config/site.config';
import { isEnabled as i18nIsEnabled } from '@/i18n';

// 1. IMPORTAÇÃO DOS HELPERS NATIVOS
import { getLocaleFromPath, localizedPath, defaultLocale } from '@/i18n';
import { getCollection } from 'astro:content';

// 2. CAPTURA DINÂMICA DO IDIOMA DA PÁGINA ATUAL
const currentLocale = getLocaleFromPath(Astro.url.pathname);
const rawNavConfigItems = getNavItems(currentLocale);

// 3. PÁGINAS LIVRES — só no locale padrão (PT-BR); sem versão EN por ora
const isDefaultLocale = !currentLocale || currentLocale === defaultLocale;
const customPageEntries = isDefaultLocale
  ? await getCollection('customPages', ({ data }) => data.showInMenu && !data.draft)
  : [];
const customNavItems = customPageEntries
  .sort((a, b) => (a.data.menuOrder ?? 99) - (b.data.menuOrder ?? 99))
  .map((entry) => ({
    label: entry.data.menuLabel || entry.data.title,
    href: `/paginas/${entry.id}`,
  }));

// TEMP-HOME-OVERRIDE: ver comentário em src/config/nav.config.ts
const homeHref = localizedPath(HOME_PATH, currentLocale);

// IMPORTAÇÃO DO UTILIÁRIO CENTRALIZADO DE REDES SOCIAIS
import { getSocialIconData } from '@/utils/icons';

export interface NavItem {
  label: string;
  href: string;
}

export interface HeaderAction {
  icon: string;
  href: string;
  label: string;
  iconOnly?: boolean;
  target?: string;
}

interface Props extends HTMLAttributes<'header'> {
  layout?: 'default' | 'centered' | 'minimal';
  position?: 'fixed' | 'sticky' | 'static';
  size?: 'sm' | 'md' | 'lg';
  variant?: 'default' | 'solid' | 'transparent';
  colorScheme?: 'default' | 'invert';
  shape?: 'bar' | 'floating';
  nav?: NavItem[];
  extraNav?: NavItem[];
  showCta?: boolean;
  cta?: { label?: string; href?: string; icon?: string; trailingIcon?: string };
  actions?: HeaderAction[];
  showThemeToggle?: boolean;
  showThemeSelector?: boolean;
  showMobileMenu?: boolean;
  showActiveState?: boolean;
  logoText?: string;
  hideLogo?: boolean;
  showLanguageSwitcher?: boolean;
  showSocialLinks?: boolean;
  showScrollProgress?: boolean;
  scrollProgressPosition?: 'top' | 'bottom';
  autoHide?: boolean;
  invertOnReturn?: boolean;
  maxWidth?: '4xl' | '5xl' | '6xl' | '7xl' | 'full';
}

const {
  layout = 'default',
  position = 'fixed',
  size = 'lg',
  variant = 'solid',
  colorScheme = 'default',
  shape = 'bar',
  nav,
  extraNav = [],
  showCta = false,
  cta = { label: 'Start a project', href: '/contato' },
  actions = [],
  showThemeToggle = true,
  showThemeSelector = true,
  showMobileMenu = true,
  showSocialLinks = false,
  showLanguageSwitcher = true, // 🌟 FORÇADO COMO TRUE PARA EVITAR SUMIÇOS
  showActiveState = true,
  showScrollProgress = false,
  scrollProgressPosition = 'bottom',
  autoHide = true,
  invertOnReturn = true,
  logoText,
  hideLogo = false,
  maxWidth = '6xl',
  class: className,
  ...attrs
} = Astro.props;

const isFloating = shape === 'floating';
const maxWidthClass = {
  '4xl': 'max-w-4xl',
  '5xl': 'max-w-5xl',
  '6xl': 'max-w-6xl',
  '7xl': 'max-w-7xl',
  full: 'max-w-full',
}[maxWidth];
const effectiveShowScrollProgress = showScrollProgress || (isFloating && !autoHide);
const isInvert = colorScheme === 'invert';
const defaultNav = [
  ...getNavItems(currentLocale).map((item: NavConfigItem) => ({
    label: item.label,
    href: localizedPath(item.href, currentLocale),
  })),
  ...customNavItems,
];
const navItems: NavItem[] = nav ? nav.map(item => ({ ...item, href: localizedPath(item.href, currentLocale) })) : [...extraNav, ...defaultNav];

const currentPath = Astro.url.pathname;

const detectedLocale = Astro.currentLocale || (currentPath.startsWith('/pt') ? 'pt' : 'en');
const isPt = detectedLocale.startsWith('pt');

const ui = {
  navigate: isPt ? 'Navegar' : 'Navigate',
  modo: isPt ? 'Modo' : 'Mode',
  cor: isPt ? 'Cor' : 'Colour',
  language: isPt ? 'Idioma' : 'Language',
  socialLinks: isPt ? 'Redes Sociais' : 'Social links',
};
const isLandingPage = currentPath === '/';
const ctaHref = cta.href?.startsWith('#') && !isLandingPage
  ? `/${cta.href}`
  : cta.href?.startsWith('#') || cta.href?.startsWith('http')
    ? cta.href
    : localizedPath(cta.href, currentLocale);

const hasLogoSlot = Astro.slots.has('logo');
const hasNavSlot = Astro.slots.has('nav');
const hasActionsSlot = Astro.slots.has('actions');
const hasMobileMenuSlot = Astro.slots.has('mobile-menu');
const headerClasses = cn(
  headerVariants({ position, variant, shape }),
  isInvert && !isFloating && 'invert-section',
  className
);
const innerClasses = cn(headerInnerVariants({ size, shape }), !isFloating && maxWidthClass);

function isActive(href: string): boolean {
  if (!showActiveState) return false;
  if (href.startsWith('#')) return false;
  return currentPath === href || currentPath.startsWith(href + '/');
}

function getNavIcon(href: string): string {
  if (href === '/' || href === '') return 'home';
  if (href.startsWith('/blog'))                        return 'pen-line';
  if (href.includes('/projects') || href.includes('/portfolio')) return 'layers';
  if (href.includes('/about') || href.includes('/sobre'))        return 'user';
  if (href.includes('/contact') || href.includes('/contato'))    return 'mail';
  if (href.includes('#servicos') || href.includes('#services'))     return 'workflow';
  if (href.includes('#depoimentos') || href.includes('#testimonials')) return 'star';
  if (href.startsWith('#') || href.includes('/#'))     return 'hash';
  if (href.startsWith('http'))                         return 'arrow-up-right';
  return 'chevron-right';
}

const mobileSocialOrder = ['x.com', 'instagram.com', 'bsky.app', 'github.com', 'linkedin.com', 'youtube.com', 'share.google', 'maps.google'];
const mobileSocialLinks = mobileSocialOrder
  .map((host) => siteConfig.socialLinks.find((u) => u.includes(host)))
  .filter((u): u is string => Boolean(u));
const menuId = `mobile-menu-${Math.random().toString(36).slice(2, 9)}`;
const buttonId = `${menuId}-button`;
---

<header
  class={headerClasses}
  data-menu-id={menuId}
  data-button-id={buttonId}
  data-header-shape={shape}
  data-header-variant={variant}
  data-header-color-scheme={colorScheme}
  data-header-auto-hide={autoHide ? 'true' : 'false'}
  data-header-invert-on-return={invertOnReturn ? 'true' : 'false'}
  {...attrs}
>
  <div class={cn(innerClasses, 'hdr-inner')}>
    {
      !hideLogo &&
        (hasLogoSlot ? (
          <slot name="logo" />
        ) : (
          <a href={homeHref} class="flex items-center gap-2 hdr-logo-text" aria-label={isPt ? 'Monto IA — Página inicial' : 'Monto IA — Home'}>
            <Logo size={size === 'sm' ? 'md' : 'lg'} forceDark={isInvert} />
          </a>
        ))
    }

    {
      layout !== 'minimal' &&
        (hasNavSlot ? (
        <nav class="hidden items-center gap-1 md:flex relative" aria-label="Main navigation">
          <div class="nav-elastic-pill" aria-hidden="true"></div>
          {navItems.map(({ label, href }) => (
            <a
              href={href}
              class={cn(
                'nav-link relative rounded-md px-3 py-2 text-sm',
                'transition-colors duration-(--transition-fast)',
                isFloating && 'hdr-invert-text',
                isFloating
                  ? (isActive(href) ? 'hdr-nav-active font-semibold' : 'font-medium')
                  : (isActive(href)
                      ? 'nav-link-active font-semibold text-foreground'
                      : 'nav-link-inactive font-medium text-foreground-muted hover:text-foreground')
              )}
              aria-current={isActive(href) ? 'page' : undefined}
            >
              {label}
            </a>
          ))}
        </nav>
        ) : (
          <nav class="hidden items-center gap-1 md:flex relative" aria-label="Main navigation">
            <div class="nav-elastic-pill" aria-hidden="true"></div>
            {navItems.map(({ label, href }) => (
              <a
                href={href.startsWith('#') && !isLandingPage ? `/${href}` : href}
                class={cn(
                  'nav-link relative rounded-md px-3 py-2 text-sm',
                  'transition-colors duration-(--transition-fast)',
                  isFloating && 'hdr-invert-text',
                  isFloating
                    ? (isActive(href) ? 'hdr-nav-active font-semibold' : 'font-medium')
                    : (isActive(href)
                        ? 'nav-link-active font-semibold text-foreground'
                        : 'nav-link-inactive font-medium text-foreground-muted hover:text-foreground')
                )}
                aria-current={isActive(href) ? 'page' : undefined}
              >
                {label}
              </a>
            ))}
          </nav>
        ))
    }

    <div class="flex items-center gap-2 justify-self-end">
      {
        hasActionsSlot ? (
          <slot name="actions" />
        ) : (
          <>
            {showThemeToggle && (
              <div class="hidden md:flex">
                <ThemeModeDropdown class={isFloating ? 'hdr-invert-text' : undefined} />
              </div>
            )}

            {showThemeSelector && (
              <div class="hidden md:flex">
                <ThemeSelectorDropdown class={isFloating ? 'hdr-invert-text' : undefined} />
              </div>
            )}

            {showLanguageSwitcher && (
              <div class="hidden md:flex lang-switcher-wrapper">
                <LanguageSwitcher compact class={isFloating ? 'hdr-invert-text' : undefined} />
              </div>
            )}

            {showSocialLinks && siteConfig.socialLinks.length > 0 && (
              <div class="hidden md:flex items-center gap-0.5">
                {siteConfig.socialLinks.map((url) => {
                  const { icon, label } = getSocialIconData(url);
                  return (
                    <a
                      href={url}
                      target="_blank"
                      rel="noopener noreferrer"
                      aria-label={label}
                      class={cn(
                        'rounded-md p-2 transition-colors duration-(--transition-fast)',
                        'focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring',
                        isFloating
                          ? 'hdr-invert-text'
                          : 'text-foreground-muted hover:text-foreground hover:bg-secondary/70'
                      )}
                    >
                      <Icon name={icon} size="md" />
                    </a>
                  );
                })}
              </div>
            )}

            {actions.map((action) => (
              <Button
                variant="ghost"
                size="sm"
                icon={action.iconOnly}
                href={action.href}
                target={action.target}
                aria-label={action.label}
                class={isFloating ? 'hdr-invert-text' : undefined}
              >
                <Icon name={action.icon} size="sm" />
                {!action.iconOnly && action.label}
              </Button>
            ))}

            {showCta && (
              <div class="hidden md:flex">
                <Button
                  size="sm"
                  href={ctaHref}
                  target={ctaHref?.startsWith('http') ? '_blank' : undefined}
                  class={cn('hdr-cta-brand', isFloating ? 'hdr-invert-cta' : undefined)}
                >
                  {cta.icon && <Icon name={cta.icon} size="sm" />}
                  {cta.label}
                  {cta.trailingIcon && <Icon name={cta.trailingIcon} size="sm" />}
                </Button>
              </div>
            )}
          </>
        )
      }

      <Search class={isFloating ? 'hdr-invert-text' : undefined} />

      {
        showMobileMenu && layout !== 'minimal' && (
          <button
            type="button"
            id={buttonId}
            class={cn(
              'hdr-hamburger inline-flex items-center justify-center rounded-md p-2 md:hidden',
              'text-brand-600 dark:text-foreground',
              'transition-colors',
              'focus-visible:ring-ring focus-visible:ring-2 focus-visible:outline-none',
              isFloating ? 'hover:bg-secondary/40' : 'hover:bg-secondary'
            )}
            aria-expanded="false"
            aria-controls={menuId}
            aria-label="Toggle menu"
          >
            <span class="menu-icon">
              <Icon name="menu" size="md" />
            </span>
            <span class="close-icon hidden">
              <Icon name="x" size="md" />
            </span>
          </button>
        )
      }
    </div>
  </div>

  {effectiveShowScrollProgress && (
    isFloating ? (
      <div
        class={`absolute inset-x-3 h-[2px] overflow-hidden rounded-full ${scrollProgressPosition === 'top' ? 'top-[2px]' : 'bottom-[2px]'}`}
        aria-hidden="true"
      >
        <div
          id="scroll-progress-bar"
          class="absolute left-0 top-0 h-full w-0 bg-brand-500 transition-none"
        />
      </div>
    ) : (
      <div
        id="scroll-progress-bar"
        class={`absolute left-0 h-[2px] w-0 bg-brand-500 transition-none ${scrollProgressPosition === 'top' ? 'top-0' : 'bottom-0'}`}
        aria-hidden="true"
      />
    )
  )}

  {
    showMobileMenu &&
      layout !== 'minimal' &&
      (hasMobileMenuSlot ? (
        <div
          id={menuId}
          class={cn(
            'hidden origin-top scale-y-0 opacity-0 shadow-[0_8px_24px_-12px_rgba(0,0,0,0.12)] md:hidden',
            isFloating
              ? 'rounded-b-2xl bg-background/95 backdrop-blur-xl'
              : 'border-border bg-background border-t'
          )}
          role="navigation"
          aria-label="Mobile navigation"
        >
          <slot name="mobile-menu" />
        </div>
      ) : (
        <div
          id={menuId}
          class={cn(
            'hidden origin-top scale-y-0 opacity-0 shadow-[0_8px_24px_-12px_rgba(0,0,0,0.12)] md:hidden',
            isFloating
              ? 'rounded-b-2xl bg-background/95 backdrop-blur-xl'
              : 'border-border bg-background border-t'
          )}
          role="navigation"
          aria-label="Mobile navigation"
        >
          <div class={cn(
            'mobile-menu-body',
            isFloating ? 'px-3' : cn('mx-auto px-4', maxWidthClass)
          )}>

            {/* ── Área com scroll: Redes Sociais + Navegar + CTA ── */}
            <div class="mobile-menu-scroll py-3">

              {/* REDES SOCIAIS — topo, label sr-only */}
              {mobileSocialLinks.length > 0 && (
                <section class="mobile-menu-section mobile-social-top">
                  <p class="sr-only">{ui.socialLinks}</p>
                  <div class="flex flex-wrap items-center gap-2 px-2 pt-1 pb-2">
                    {mobileSocialLinks.map((url, sIdx) => {
                      const { icon, label } = getSocialIconData(url);
                      return (
                        <a
                          href={url}
                          target="_blank"
                          rel="noopener noreferrer"
                          aria-label={label}
                          title={label}
                          class="mobile-menu-social mobile-menu-stagger inline-flex h-11 w-11 items-center justify-center rounded-full border border-border-strong text-foreground-muted transition-colors"
                          style={`--stagger-index: ${sIdx}`}
                        >
                          <Icon name={icon} size="md" />
                        </a>
                      );
                    })}
                  </div>
                </section>
              )}

              {/* NAVEGAR */}
              <section class="mobile-menu-section">
                <p class="sr-only">{ui.navigate}</p>
                <ul class="space-y-0.5">
                  {navItems.map(({ label, href }, idx) => {
                    const active = isActive(href);
                    const resolvedHref = href.startsWith('#') && !isLandingPage ? `/${href}` : href;
                    return (
                      <li>
                        <a
                          href={resolvedHref}
                          class={cn(
                            'mobile-menu-row mobile-menu-stagger group flex items-center gap-3 rounded-xl px-3 py-3 text-base transition-colors',
                            active ? 'mobile-menu-row-active' : 'mobile-menu-row-inactive'
                          )}
                          style={`--stagger-index: ${mobileSocialLinks.length + idx}`}
                          aria-current={active ? 'page' : undefined}
                        >
                          <span class="mobile-menu-tile">
                            <Icon name={getNavIcon(href)} size="sm" />
                          </span>
                          <span class="flex-1">{label}</span>
                          <Icon name="chevron-right" size="sm" class="mobile-menu-chevron" />
                        </a>
                      </li>
                    );
                  })}
                </ul>
              </section>

              {showCta && (
                <div
                  class="mobile-menu-stagger mobile-menu-cta-wrap pt-2"
                  style={`--stagger-index: ${mobileSocialLinks.length + navItems.length}`}
                >
                  <Button fullWidth href={ctaHref} target={ctaHref?.startsWith('http') ? '_blank' : undefined}>
                    {cta.icon && <Icon name={cta.icon} size="sm" />}
                    {cta.label}
                    {cta.trailingIcon && <Icon name={cta.trailingIcon} size="sm" />}
                  </Button>
                </div>
              )}

            </div>

            {/* ── Configurações: Modo | Cor | Idioma — fora do scroll, dropdowns sem clipping ── */}
            {(showThemeToggle || showThemeSelector || showLanguageSwitcher) && (
              <section class="mobile-settings-row">
                <div
                  class="mobile-settings-grid mobile-menu-stagger"
                  style={`--stagger-index: ${mobileSocialLinks.length + navItems.length + 1}`}
                >
                  {showThemeToggle && (
                    <div class="mobile-settings-col">
                      <span class="mobile-settings-label">{ui.modo}</span>
                      <ThemeModeDropdown />
                    </div>
                  )}
                  {showThemeSelector && (
                    <div class="mobile-settings-col">
                      <span class="mobile-settings-label">{ui.cor}</span>
                      <div class="relative mobile-color-picker">
                        <button
                          type="button"
                          class="mobile-color-trigger inline-flex items-center gap-1.5 rounded-full border border-border-strong px-2.5 py-1.5 text-foreground-muted hover:text-foreground hover:bg-secondary transition-colors duration-(--transition-fast) focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2"
                          aria-expanded="false"
                          aria-haspopup="dialog"
                          aria-label={isPt ? 'Cor do tema' : 'Colour theme'}
                        >
                          <span class="h-3.5 w-3.5 rounded-full flex-shrink-0 block" style="background-color: var(--color-brand-500)" aria-hidden="true" />
                          <svg class="mobile-color-chevron h-3 w-3 flex-shrink-0 transition-transform duration-200" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <path d="m6 9 6 6 6-6"/>
                          </svg>
                        </button>
                        <div
                          class="mobile-color-panel hidden p-2 rounded-xl border border-border bg-background shadow-lg w-max"
                          role="dialog"
                          aria-label={isPt ? 'Cor do tema' : 'Colour theme'}
                        >
                          <ThemeSelector />
                        </div>
                      </div>
                    </div>
                  )}
                  {showLanguageSwitcher && (
                    <div class="mobile-settings-col">
                      <span class="mobile-settings-label">{ui.language}</span>
                      <LanguageSwitcher compact />
                    </div>
                  )}
                </div>
              </section>
            )}
          </div>
        </div>
      ))
  }
</header>

{
  showMobileMenu && layout !== 'minimal' && (
    <div
      id={`${menuId}-backdrop`}
      class="pointer-events-none fixed inset-0 z-40 opacity-0 transition-opacity duration-200 md:hidden"
      aria-hidden="true"
    />
  )
}

<script>
  function initMobileMenu() {
    const menuHeaders = document.querySelectorAll<HTMLElement>('header[data-menu-id]');
    menuHeaders.forEach((header) => {
      const menuId = header.dataset.menuId!;
      const buttonId = header.dataset.buttonId!;
      const isFloating = header.dataset.headerShape === 'floating';

      const button = document.getElementById(buttonId);
      const menu = document.getElementById(menuId);
      const backdrop = document.getElementById(`${menuId}-backdrop`);
      const menuIcon = button?.querySelector('.menu-icon');
      const closeIcon = button?.querySelector('.close-icon');

      if (!button || !menu || !menuIcon || !closeIcon) return;
      if (button.dataset.menuInit) return;
      button.dataset.menuInit = 'true';

      let isOpen = false;
      let isAnimating = false;

      function open() {
        if (isOpen || isAnimating) return;
        isAnimating = true;
        isOpen = true;

        button!.setAttribute('aria-expanded', 'true');
        menuIcon!.classList.add('hidden');
        closeIcon!.classList.remove('hidden');

        if (isFloating) {
          header.setAttribute('data-scrolled', '');
          header.classList.remove('rounded-2xl');
          header.classList.add('rounded-t-2xl');
        } else {
          header.classList.add('!bg-background');
        }

        const mainContent = document.querySelector('main');
        const footer = document.querySelector('footer');
        if (mainContent) mainContent.classList.add('mobile-menu-blur');
        if (footer) footer.classList.add('mobile-menu-blur');

        menu!.classList.remove('hidden', 'animate-menu-up', 'opacity-0', 'scale-y-0');
        menu!.classList.add('animate-menu-down');
        if (backdrop) {
          backdrop.classList.remove('pointer-events-none', 'animate-backdrop-out');
          backdrop.classList.add('animate-backdrop');
        }

        isAnimating = false;
      }

      function close() {
        if (!isOpen || isAnimating) return;
        isAnimating = true;

        button!.setAttribute('aria-expanded', 'false');
        menuIcon!.classList.remove('hidden');
        closeIcon!.classList.add('hidden');

        menu!.classList.remove('animate-menu-down');
        menu!.classList.add('animate-menu-up');
        if (backdrop) {
          backdrop.classList.remove('animate-backdrop');
          backdrop.classList.add('animate-backdrop-out');
        }

        const mainContent = document.querySelector('main');
        const footer = document.querySelector('footer');
        if (mainContent) mainContent.classList.remove('mobile-menu-blur');
        if (footer) footer.classList.remove('mobile-menu-blur');

        setTimeout(() => {
          menu!.classList.add('hidden', 'opacity-0', 'scale-y-0');
          if (backdrop) {
            backdrop.classList.add('pointer-events-none');
          }

          if (isFloating) {
            header.classList.remove('rounded-t-2xl');
            header.classList.add('rounded-2xl');
            if (window.scrollY <= 60) {
              header.removeAttribute('data-scrolled');
            }
          } else {
            header.classList.remove('!bg-background');
          }

          isOpen = false;
          isAnimating = false;
        }, 200);
      }

      function toggle() {
        if (isOpen) {
          close();
        } else {
          open();
        }
      }

      button.addEventListener('click', toggle);
      if (backdrop) {
        backdrop.addEventListener('click', close);
      }

      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape' && isOpen) {
          close();
        }
      });
      menu.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', close);
      });
    });
  }

  initMobileMenu();
  document.addEventListener('astro:page-load', initMobileMenu);
  document.addEventListener('astro:after-swap', initMobileMenu);
</script>

<script>
  function initMobileColorPicker() {
    // Settings row agora fica fora do scroll container — dropdowns abrem via CSS (sem JS de posição)

    function closeAllSettingsPanels() {
      document.querySelectorAll<HTMLElement>('.ttg-panel').forEach(p => p.classList.add('hidden'));
      document.querySelectorAll<HTMLButtonElement>('.ttg-trigger').forEach(t => t.setAttribute('aria-expanded', 'false'));
      document.querySelectorAll<HTMLElement>('.lang-panel').forEach(p => p.classList.add('hidden'));
      document.querySelectorAll<HTMLButtonElement>('.lang-trigger').forEach(t => t.setAttribute('aria-expanded', 'false'));
      document.querySelectorAll<HTMLElement>('.mobile-color-panel').forEach(p => p.classList.add('hidden'));
      document.querySelectorAll<HTMLButtonElement>('.mobile-color-trigger').forEach(t => {
        t.setAttribute('aria-expanded', 'false');
        t.querySelector('.mobile-color-chevron')?.classList.remove('rotate-180');
      });
    }

    // Cross-close: cada trigger fecha os outros dois (capture phase → antes do handler nativo)
    function initCrossClose() {
      const row = document.querySelector<HTMLElement>('.mobile-settings-row');
      if (!row || row.dataset.panelWatchInit) return;
      row.dataset.panelWatchInit = 'true';

      const closeLang = () => {
        document.querySelectorAll<HTMLElement>('.lang-panel').forEach(p => p.classList.add('hidden'));
        document.querySelectorAll<HTMLButtonElement>('.lang-trigger').forEach(t => {
          t.setAttribute('aria-expanded', 'false');
          t.querySelector('.lang-chevron')?.classList.remove('rotate-180');
        });
      };
      const closeTtg = () => {
        document.querySelectorAll<HTMLElement>('.ttg-panel').forEach(p => p.classList.add('hidden'));
        document.querySelectorAll<HTMLButtonElement>('.ttg-trigger').forEach(t => t.setAttribute('aria-expanded', 'false'));
      };
      const closeColor = () => {
        document.querySelectorAll<HTMLElement>('.mobile-color-panel').forEach(p => p.classList.add('hidden'));
        document.querySelectorAll<HTMLButtonElement>('.mobile-color-trigger').forEach(t => {
          t.setAttribute('aria-expanded', 'false');
          t.querySelector('.mobile-color-chevron')?.classList.remove('rotate-180');
        });
      };

      const ttgTrigger = row.querySelector<HTMLButtonElement>('.ttg-trigger');
      const langTrigger = row.querySelector<HTMLButtonElement>('.lang-trigger');

      ttgTrigger?.addEventListener('click', () => { closeLang(); closeColor(); }, true);
      langTrigger?.addEventListener('click', () => { closeTtg(); closeColor(); }, true);
    }

    // Color picker mobile
    document.querySelectorAll<HTMLElement>('.mobile-color-picker').forEach(picker => {
      if (picker.dataset.colorPickerInit) return;
      picker.dataset.colorPickerInit = 'true';

      const trigger = picker.querySelector<HTMLButtonElement>('.mobile-color-trigger');
      const panel = picker.querySelector<HTMLElement>('.mobile-color-panel');
      if (!trigger || !panel) return;

      trigger.addEventListener('click', (e) => {
        e.stopPropagation();
        const willOpen = panel.classList.contains('hidden');
        closeAllSettingsPanels();
        if (willOpen) {
          panel.classList.remove('hidden');
          trigger.setAttribute('aria-expanded', 'true');
          trigger.querySelector('.mobile-color-chevron')?.classList.add('rotate-180');
        }
      });

      panel.querySelectorAll<HTMLButtonElement>('.theme-swatch').forEach(swatch => {
        swatch.addEventListener('click', () => {
          panel.classList.add('hidden');
          trigger.setAttribute('aria-expanded', 'false');
          trigger.querySelector('.mobile-color-chevron')?.classList.remove('rotate-180');
        });
      });
    });

    initCrossClose();

    // Handlers globais (único registro via flag)
    if (!(window as unknown as { __mobileColorPickerGlobalInit?: boolean }).__mobileColorPickerGlobalInit) {
      (window as unknown as { __mobileColorPickerGlobalInit?: boolean }).__mobileColorPickerGlobalInit = true;

      document.addEventListener('click', (e) => {
        const openPanel = document.querySelector<HTMLElement>('.mobile-color-panel:not(.hidden)');
        if (!openPanel) return;
        const picker = openPanel.closest('.mobile-color-picker');
        if (picker && !picker.contains(e.target as Node)) {
          openPanel.classList.add('hidden');
          const t = picker.querySelector<HTMLButtonElement>('.mobile-color-trigger');
          if (t) {
            t.setAttribute('aria-expanded', 'false');
            t.querySelector('.mobile-color-chevron')?.classList.remove('rotate-180');
          }
        }
      });

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closeAllSettingsPanels();
      });

      document.addEventListener('click', (e) => {
        if ((e.target as Element)?.closest('.hdr-hamburger')) closeAllSettingsPanels();
      }, true);
    }
  }

  initMobileColorPicker();
  document.addEventListener('astro:page-load', initMobileColorPicker);
  document.addEventListener('astro:after-swap', initMobileColorPicker);

  // ── Cross-close desktop: ThemeSelector, TTG e LanguageSwitcher não ficam abertos juntos ──
  function initDesktopCrossClose() {
    if ((window as unknown as { __desktopCrossCloseInit?: boolean }).__desktopCrossCloseInit) return;
    (window as unknown as { __desktopCrossCloseInit?: boolean }).__desktopCrossCloseInit = true;

    const closeThemeDd = () => {
      const p = document.getElementById('theme-dropdown-panel');
      const t = document.getElementById('theme-dropdown-trigger');
      p?.classList.add('hidden');
      t?.setAttribute('aria-expanded', 'false');
      t?.querySelector('.theme-chevron')?.classList.remove('rotate-180');
    };
    const closeTtg = () => {
      document.querySelectorAll<HTMLElement>('.ttg-panel').forEach(p => p.classList.add('hidden'));
      document.querySelectorAll<HTMLButtonElement>('.ttg-trigger').forEach(t => t.setAttribute('aria-expanded', 'false'));
    };
    const closeLang = () => {
      document.querySelectorAll<HTMLElement>('.lang-panel').forEach(p => p.classList.add('hidden'));
      document.querySelectorAll<HTMLButtonElement>('.lang-trigger').forEach(t => {
        t.setAttribute('aria-expanded', 'false');
        t.querySelector('.lang-chevron')?.classList.remove('rotate-180');
      });
    };

    // Seleciona somente os triggers do desktop (fora da .mobile-settings-row)
    const desktopTtg = [...document.querySelectorAll<HTMLButtonElement>('.ttg-trigger')]
      .find(el => !el.closest('.mobile-settings-row'));
    const desktopLang = [...document.querySelectorAll<HTMLButtonElement>('.lang-trigger')]
      .find(el => !el.closest('.mobile-settings-row'));

    // Capture phase: dispara ANTES dos handlers nativos de cada componente
    document.getElementById('theme-dropdown-trigger')?.addEventListener('click', () => { closeTtg(); closeLang(); }, true);
    desktopTtg?.addEventListener('click', () => { closeThemeDd(); closeLang(); }, true);
    desktopLang?.addEventListener('click', () => { closeThemeDd(); closeTtg(); }, true);
  }

  initDesktopCrossClose();
  document.addEventListener('astro:page-load', initDesktopCrossClose);
  document.addEventListener('astro:after-swap', initDesktopCrossClose);

  // ── Elastic pill: efeito de hover no nav desktop (apenas bar header) ──
  function initNavElasticPill() {
    const header = document.querySelector<HTMLElement>('[data-header-shape]');
    if (!header || header.dataset.headerShape !== 'bar') return;

    document.querySelectorAll<HTMLElement>('nav[aria-label="Main navigation"]').forEach(nav => {
      if (nav.dataset.pillInit) return;
      nav.dataset.pillInit = 'true';

      const pill = nav.querySelector<HTMLElement>('.nav-elastic-pill');
      if (!pill) return;

      const links = [...nav.querySelectorAll<HTMLElement>('.nav-link')];
      if (!links.length) return;

      let active = links.find(l =>
        l.classList.contains('nav-link-active') || l.classList.contains('hdr-nav-active')
      ) || links[0];

      function moveTo(el: HTMLElement) {
        pill!.style.width = el.offsetWidth + 'px';
        pill!.style.transform = `translateX(${el.offsetLeft}px)`;
      }

      // Posição inicial instantânea (sem transição)
      pill.style.transition = 'none';
      pill.style.opacity = '1';
      moveTo(active);
      nav.classList.add('hdr-nav-pill-active');
      requestAnimationFrame(() => { pill.style.transition = ''; });

      links.forEach(link => {
        link.addEventListener('mouseenter', () => moveTo(link));
        link.addEventListener('click', () => { active = link; });
      });

      nav.addEventListener('mouseleave', () => moveTo(active));
    });
  }

  initNavElasticPill();
  document.addEventListener('astro:page-load', initNavElasticPill);
  document.addEventListener('astro:after-swap', initNavElasticPill);
</script>

<script>
  const SCROLL_THRESHOLD = 60;
  const AUTO_HIDE_THRESHOLD = 150;
  const BAR_SCROLLED_CLASSES = ['bg-background/80', 'backdrop-blur-lg', 'border-b', 'border-border/50'];

  let docMaxScrollY = 0;
  let docMetricsInited = false;
  function updateDocMaxScrollY() {
    docMaxScrollY = document.documentElement.scrollHeight - window.innerHeight;
  }
  function initDocMetrics() {
    if (docMetricsInited) return;
    docMetricsInited = true;
    window.addEventListener('resize', updateDocMaxScrollY, { passive: true });
    if (typeof ResizeObserver !== 'undefined') {
      new ResizeObserver(updateDocMaxScrollY).observe(document.documentElement);
    }
  }

  function initScrollDriven() {
    initDocMetrics();
    const scrollHeaders = document.querySelectorAll<HTMLElement>(
      'header[data-header-shape="floating"], header[data-header-shape="bar"]'
    );
    const progressBar = document.getElementById('scroll-progress-bar');
    scrollHeaders.forEach((header) => {
      if (header.dataset.scrollInit) return;
      header.dataset.scrollInit = 'true';

      const isBar = header.dataset.headerShape === 'bar';
      const isFloating = header.dataset.headerShape === 'floating';
      const isAutoHide = header.dataset.headerAutoHide !== 'false';
      const isTransparentBar = isBar && header.dataset.headerVariant === 'transparent';
      let ticking = false;
      let lastScrollY = window.scrollY;
      let lastShownAtY = 0;

      function onScroll() {
        if (ticking) return;
        ticking = true;

        requestAnimationFrame(() => {
          const currentScrollY = window.scrollY;
          const menuId = header.dataset.menuId;
          const menu = menuId ? document.getElementById(menuId) : null;
          const menuOpen = menu && !menu.classList.contains('hidden');
          const wasHidden = header.hasAttribute('data-header-hidden');

          if (currentScrollY > SCROLL_THRESHOLD) {
            header.setAttribute('data-scrolled', '');
            if (isTransparentBar) {
              header.classList.add(...BAR_SCROLLED_CLASSES);
              header.classList.remove('bg-transparent');
            }
          } else {
            if (!menuOpen) {
              header.removeAttribute('data-scrolled');
              header.removeAttribute('data-header-hidden');
              lastShownAtY = 0;
              if (isTransparentBar) {
                header.classList.remove(...BAR_SCROLLED_CLASSES);
                header.classList.add('bg-transparent');
              }
            }
          }

          if (isFloating && isAutoHide && !menuOpen) {
            if (currentScrollY > AUTO_HIDE_THRESHOLD) {
              if (currentScrollY > lastScrollY) {
                if (currentScrollY - lastShownAtY >= AUTO_HIDE_THRESHOLD) {
                  header.setAttribute('data-header-hidden', '');
                }
              } else {
                if (wasHidden) {
                  lastShownAtY = Math.min(
                    currentScrollY,
                    Math.max(0, docMaxScrollY - AUTO_HIDE_THRESHOLD)
                  );
                  header.setAttribute('data-header-returned', '');
                }
                header.removeAttribute('data-header-hidden');
              }
            } else {
              header.removeAttribute('data-header-hidden');
              header.removeAttribute('data-header-returned');
              lastShownAtY = 0;
            }
          }

          if (progressBar) {
            const pct = docMaxScrollY > 0 ? (currentScrollY / docMaxScrollY) * 100 : 0;
            progressBar.style.width = `${pct}%`;
          }

          lastScrollY = currentScrollY;
          ticking = false;
        });
      }

      window.addEventListener('scroll', onScroll, { passive: true });
      requestAnimationFrame(() => {
        updateDocMaxScrollY();
        onScroll();
      });
    });

    if (progressBar && scrollHeaders.length === 0 && !progressBar.dataset.progressInit) {
      progressBar.dataset.progressInit = 'true';
      let pTicking = false;
      const updateProgress = () => {
        const pct = docMaxScrollY > 0 ? (window.scrollY / docMaxScrollY) * 100 : 0;
        progressBar.style.width = `${pct}%`;
        pTicking = false;
      };
      window.addEventListener(
        'scroll',
        () => {
          if (!pTicking) {
            pTicking = true;
            requestAnimationFrame(updateProgress);
          }
        },
        { passive: true }
      );
      requestAnimationFrame(() => {
        updateDocMaxScrollY();
        updateProgress();
      });
    }
  }

  initScrollDriven();
  document.addEventListener('astro:page-load', initScrollDriven);
  document.addEventListener('astro:after-swap', initScrollDriven);
</script>

