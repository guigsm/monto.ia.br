---
import { cn } from '@/lib/cn';

interface Props {
  size?: 'sm' | 'md' | 'lg';
  forceDark?: boolean;
  class?: string;
}

const { size, forceDark, class: className } = Astro.props;

// 🌟 DETECÇÃO BLINDADA: O Header é o único componente que passa a prop 'forceDark'
const isHeader = forceDark !== undefined;

// Se for o logo do topo (Header), escala conforme o combinado. Se for secundário, ignora o size herdado e força h-6 fixo.
const sizeClass = isHeader 
  ? (size === 'lg' ? 'h-10' : size === 'md' ? 'h-9' : 'h-8') 
  : 'h-7';
