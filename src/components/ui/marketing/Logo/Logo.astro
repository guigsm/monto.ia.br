<style>
  /* ====================================================
   * UNIVERSO A: LOGO PRINCIPAL (Header / Topo do Site)
   * Totalmente colorido com o tema e reativo às rolagens.
   * ==================================================== */
  .header-logo .s0 { 
    fill: var(--color-brand-500, #0068d6) !important; 
    transition: fill 0.3s ease;
  } 
  .header-logo .s1 { fill: #ffffff !important; } 
  
  /* Letras "onto" controladas pelo scroll do topo */
  .header-logo .s2 { 
    fill: #3b3b3b !important; 
    transition: fill 0.3s ease-in-out;
  } 
  :global(.dark) .header-logo .s2 {
    fill: #ffffff !important;
  }
  /* Contraste translúcido antes do scroll sobre o Hero escuro */
  :global(header[data-header-shape="floating"]:not([data-scrolled])) .header-logo .s2,
  :global(header[data-header-color-scheme="invert"]:not([data-scrolled])) .header-logo .s2 {
    fill: oklch(91% 0.008 250) !important;
  }

  /* Monograma 'M' 3D Dinâmico que segue a cor ativa da sua marca */
  .header-logo .s3 { fill: var(--color-brand-300, #aaaaaa) !important; } 
  .header-logo .s4 { fill: var(--color-brand-400, #969696) !important; } 
  .header-logo .s5 { fill: var(--color-brand-500, #828282) !important; } 
  .header-logo .s6 { fill: var(--color-brand-900, #323232) !important; } 
  .header-logo .s7 { fill: var(--color-brand-950, #373737) !important; } 
  .header-logo .s8 { fill: var(--color-brand-200, #a0a0a0) !important; } 

  /* ====================================================
   * UNIVERSO B: LOGOS SECUNDÁRIOS (Cards de Posts e Rodapé)
   * 100% Monocromático, oposto do modo de tela, preservando o 3D.
   * ==================================================== */

  /* --- ⚪ LIGHT MODE GERAL (Logo Escuro - Tons Neutros de Zinco) --- */
  .general-logo .s0 { fill: #3b3b3b !important; } /* Box Escuro */
  .general-logo .s1 { fill: #ffffff !important; } /* Letras 'iA' Brancas */
  .general-logo .s2 { fill: #3b3b3b !important; } /* Texto 'onto' Escuro */
  
  /* Escala monocromática para manter relevos, sombras e entalhes sem usar cor de tema */
  .general-logo .s3 { fill: #71717a !important; } /* zinc-500 (Faces claras) */
  .general-logo .s4 { fill: #52525b !important; } /* zinc-600 (Faces médias) */
  .general-logo .s5 { fill: #3f3f46 !important; } /* zinc-700 (Sombras estruturais) */
  .general-logo .s6 { fill: #18181b !important; } /* zinc-900 (Entalhes profundos 1) */
  .general-logo .s7 { fill: #27272a !important; } /* zinc-800 (Entalhes profundos 2) */
  .general-logo .s8 { fill: #a1a1aa !important; } /* zinc-400 (Topos iluminados) */

  /* --- ⚫ DARK MODE GERAL (Logo Claro - Tons Inversos de Zinco) --- */
  :global(.dark) .general-logo .s0 { fill: #ffffff !important; } /* Box fica Branco */
  :global(.dark) .general-logo .s1 { fill: #1c1c1e !important; } /* Letras 'iA' ficam Escuras */
  :global(.dark) .general-logo .s2 { fill: #ffffff !important; } /* Texto 'onto' fica Branco */
  
  /* Inversão tonal cirúrgica para o M continuar volumétrico sobre fundos escuros */
  :global(.dark) .general-logo .s3 { fill: #e4e4e7 !important; } /* zinc-200 */
  :global(.dark) .general-logo .s4 { fill: #d4d4d8 !important; } /* zinc-300 */
  :global(.dark) .general-logo .s5 { fill: #a1a1aa !important; } /* zinc-400 */
  :global(.dark) .general-logo .s6 { fill: #71717a !important; } /* zinc-500 */
  :global(.dark) .general-logo .s7 { fill: #52525b !important; } /* zinc-600 */
  :global(.dark) .general-logo .s8 { fill: #f4f4f5 !important; } /* zinc-100 */
</style>