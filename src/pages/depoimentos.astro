---
import PageLayout from '@/layouts/PageLayout.astro';
import { Hero } from '@/components/hero';
import Button from '@/components/ui/form/Button/Button.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import LetterGlitchBand from '@/components/patterns/LetterGlitchBand.astro';
import TestimonialsGrid from '@/components/patterns/TestimonialsGrid.astro';

import { getTestimonials } from '@/lib/testimonials';
import testimonialsContent from '@/content/pages/testimonials.json';

const { reviews, meta } = await getTestimonials();

const display = reviews.slice(0, 15);
const c = testimonialsContent;
---

<PageLayout
  title={`Depoimentos — ${c.ptHeroTitle} ${c.ptHeroTitleBrand}`}
  description={`Avaliações reais de clientes dos projetos desenvolvidos pela Monto IA. ${meta.rating}★ em ${meta.count}+ avaliações no Google.`}
>
  <!-- Hero -->
  <Hero layout="centered" size="sm">
    <Badge slot="badge" variant="brand" pill>{c.ptBadge}</Badge>
    <h1 slot="title">
      {c.ptHeroTitle}
      <span class="text-brand-500"> {c.ptHeroTitleBrand}</span>
    </h1>
    <p slot="description">{c.ptHeroDescription}</p>
  </Hero>

  <!-- Rating summary -->
  <section class="relative z-10 py-10 bg-background-secondary border-t border-border">
    <div class="mx-auto max-w-6xl px-6">
      <div class="flex flex-col sm:flex-row items-center justify-center gap-8 sm:gap-16" data-reveal>
        <div class="text-center">
          <p class="font-display text-6xl font-bold text-foreground">
            {meta.rating}<span class="text-brand-500">★</span>
          </p>
          <p class="text-sm text-foreground-muted mt-1">{c.ptRatingLabel}</p>
        </div>
        <div class="h-px w-16 sm:h-16 sm:w-px bg-border"></div>
        <div class="text-center">
          <p class="font-display text-6xl font-bold text-foreground">
            {meta.count}<span class="text-brand-500">+</span>
          </p>
          <p class="text-sm text-foreground-muted mt-1">{c.ptReviewsLabel}</p>
        </div>
        <div class="h-px w-16 sm:h-16 sm:w-px bg-border"></div>
        <div class="text-center">
          <div class="flex justify-center gap-1 mb-1" role="img" aria-label="5 de 5 estrelas">
            {[...Array(5)].map(() => (
              <svg class="w-6 h-6 fill-brand-500" viewBox="0 0 20 20" aria-hidden="true">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <p class="text-sm text-foreground-muted">{c.ptStarsLabel}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Grid de depoimentos -->
  <section class="relative z-10 py-[var(--space-section-md)] bg-background border-t border-border">
    <div class="mx-auto max-w-6xl px-6 flex flex-col gap-8">
      <div class="text-center" data-reveal>
        <Badge variant="brand" pill class="mb-4">{c.ptSectionBadge}</Badge>
        <h2 class="font-display text-2xl md:text-3xl font-bold text-foreground">
          {c.ptSectionTitle}
        </h2>
        <p class="text-foreground-muted mt-2 max-w-xl mx-auto text-sm">
          {c.ptSectionDescription}
        </p>
      </div>

      <TestimonialsGrid reviews={display} columns={3} locale="pt-br" />

      <!-- Ver todos no Google -->
      <div class="flex justify-center pt-4" data-reveal>
        <Button
          variant="outline"
          href={meta.writeAReviewUri}
          target="_blank"
          rel="noopener noreferrer"
          class="gap-2"
        >
          {c.ptViewAllButton}
          <Icon name="external-link" size="sm" />
        </Button>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <LetterGlitchBand>
    <h2 class="font-display text-4xl font-bold text-foreground mb-4 text-balance">
      {c.ptCtaTitle}
    </h2>
    <p class="text-lg text-foreground-muted mb-8 text-balance">
      {c.ptCtaDescription}
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <Button size="lg" href="/contato" class="hero-btn-brand">
        {c.ptCtaButton1}
        <Icon name="arrow-right" size="sm" />
      </Button>
      <Button size="lg" variant="outline" href="/portfolio">
        {c.ptCtaButton2}
        <Icon name="layers" size="sm" />
      </Button>
    </div>
  </LetterGlitchBand>
</PageLayout>
