---
/**
 * Depoimentos page
 * URL: /depoimentos
 *
 * Lê os depoimentos de src/data/testimonials.json.
 * Esse arquivo é gerado via API e substituído automaticamente —
 * nunca edite diretamente; atualize a fonte da API.
 *
 * Estrutura esperada do JSON:
 *   { _meta: { summary: { count, rating } }, reviews: [...] }
 */
import PageLayout from '@/layouts/PageLayout.astro';
import { Hero } from '@/components/hero';
import Button from '@/components/ui/form/Button/Button.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import LetterGlitchBand from '@/components/patterns/LetterGlitchBand.astro';

import testimonialData from '@/data/testimonials.json';

const { reviews, _meta } = testimonialData;
const { count, rating } = _meta.summary;

// Iniciais do nome para o avatar fallback
function initials(name: string) {
  return name
    .split(' ')
    .slice(0, 2)
    .map((n) => n[0])
    .join('')
    .toUpperCase();
}

// Formatar data relativa simples
function formatDate(iso: string) {
  const date = new Date(iso);
  return date.toLocaleDateString('pt-BR', { month: 'long', year: 'numeric' });
}
---

<PageLayout
  title="Depoimentos — O que dizem os clientes dos projetos Monto IA"
  description={`Avaliações reais de clientes dos projetos desenvolvidos pela Monto IA. ${rating}★ em ${count}+ avaliações no Google.`}
>
  <!-- Hero -->
  <Hero layout="centered" size="sm">
    <Badge slot="badge" variant="brand" pill>Resultados reais</Badge>
    <h1 slot="title">
      O que dizem os clientes dos
      <span class="text-brand-500"> nossos projetos</span>
    </h1>
    <p slot="description">
      Avaliações reais do Google de clientes dos projetos desenvolvidos pela Monto IA.
      Resultados mensuráveis, não promessas.
    </p>
  </Hero>

  <!-- Rating summary -->
  <section class="relative z-10 py-10 bg-background-secondary border-t border-border">
    <div class="mx-auto max-w-6xl px-6">
      <div class="flex flex-col sm:flex-row items-center justify-center gap-8 sm:gap-16" data-reveal>
        <div class="text-center">
          <p class="font-display text-6xl font-bold text-foreground">{rating}<span class="text-brand-500">★</span></p>
          <p class="text-sm text-foreground-muted mt-1">Nota média no Google</p>
        </div>
        <div class="h-px w-16 sm:h-16 sm:w-px bg-border"></div>
        <div class="text-center">
          <p class="font-display text-6xl font-bold text-foreground">{count}<span class="text-brand-500">+</span></p>
          <p class="text-sm text-foreground-muted mt-1">Avaliações verificadas</p>
        </div>
        <div class="h-px w-16 sm:h-16 sm:w-px bg-border"></div>
        <div class="text-center">
          <div class="flex justify-center gap-1 mb-1" role="img" aria-label="5 de 5 estrelas">
            {[...Array(5)].map(() => (
              <svg class="w-6 h-6 fill-brand-500" viewBox="0 0 20 20" aria-hidden="true">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <p class="text-sm text-foreground-muted">100% de 5 estrelas</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Grid de depoimentos -->
  <section class="relative z-10 py-[var(--space-section-md)] bg-background border-t border-border">
    <div class="mx-auto max-w-6xl px-6 flex flex-col gap-8">
      <div class="text-center" data-reveal>
        <Badge variant="brand" pill class="mb-4">Avaliações no Google</Badge>
        <h2 class="font-display text-2xl md:text-3xl font-bold text-foreground">
          Clientes dos projetos que desenvolvemos
        </h2>
        <p class="text-foreground-muted mt-2 max-w-xl mx-auto text-sm">
          Avaliações reais e verificadas. O arquivo de depoimentos é atualizado automaticamente via API.
        </p>
      </div>

      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {reviews.map((review, i) => (
          <Card variant="elevated" padding="lg" hover data-reveal data-reveal-delay={String(i % 3)}>
            <div class="flex flex-col h-full gap-4">
              <!-- Stars -->
              <div class="flex gap-1 text-brand-500" role="img" aria-label={`${review.rating} de 5 estrelas`}>
                {[...Array(review.rating)].map(() => (
                  <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20" aria-hidden="true">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                ))}
              </div>

              <!-- Text -->
              <blockquote class="flex-1 text-sm text-foreground-muted leading-relaxed">
                "{review.text}"
              </blockquote>

              <!-- Author -->
              <div class="flex items-center gap-3 pt-4 border-t border-border">
                {review.author.avatarUrl ? (
                  <img
                    src={review.author.avatarUrl}
                    alt={review.author.name}
                    width="36"
                    height="36"
                    class="w-9 h-9 rounded-full object-cover shrink-0"
                    loading="lazy"
                  />
                ) : (
                  <div class="w-9 h-9 rounded-full bg-gradient-to-br from-brand-500/30 to-brand-500/10 flex items-center justify-center text-brand-500 font-bold text-sm shrink-0">
                    {initials(review.author.name)}
                  </div>
                )}
                <div class="min-w-0">
                  <p class="text-sm font-semibold text-foreground truncate">{review.author.name}</p>
                  <p class="text-xs text-foreground-muted">{formatDate(review.publishedAt)}</p>
                </div>
                {review.platform === 'gbp' && (
                  <div class="ml-auto shrink-0" title="Avaliação no Google">
                    <svg class="w-4 h-4 text-foreground-muted" viewBox="0 0 24 24" aria-hidden="true">
                      <path fill="currentColor" d="M12 11h8.533c.044.385.067.78.067 1.184 0 2.734-.98 5.047-2.687 6.6C16.32 20.272 14.307 21 12 21c-4.97 0-9-4.03-9-9s4.03-9 9-9c2.43 0 4.466.89 6.03 2.346L16.4 6.98A6.86 6.86 0 0 0 12 5.5C8.416 5.5 5.5 8.416 5.5 12S8.416 18.5 12 18.5c3.12 0 5.321-1.787 5.955-4.5H12V11z"/>
                    </svg>
                  </div>
                )}
              </div>
            </div>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <LetterGlitchBand>
    <h2 class="font-display text-4xl font-bold text-foreground mb-4 text-balance">
      Quer resultados assim para o seu negócio?
    </h2>
    <p class="text-lg text-foreground-muted mb-8 text-balance">
      Vamos entender o seu projeto e ver o que faz sentido — site, SEO, automação ou tudo junto.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <Button size="lg" href="/contato" class="hero-btn-brand">
        Falar com a Monto IA
        <Icon name="arrow-right" size="sm" />
      </Button>
      <Button size="lg" variant="outline" href="/portfolio">
        Ver projetos entregues
        <Icon name="layers" size="sm" />
      </Button>
    </div>
  </LetterGlitchBand>
</PageLayout>
