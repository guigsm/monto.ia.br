<script>
  function initCountup() {
    const counters = document.querySelectorAll<HTMLElement>('[data-countup]:not([data-countup-init])');
    if (counters.length === 0) return;
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        observer.unobserve(entry.target);
        const el = entry.target as HTMLElement;
        const target = parseInt(el.dataset.countup ?? '0', 10);
        const suffix = el.dataset.suffix ?? '';
        const duration = 1200;
        const start = performance.now();
        const tick = (now: number) => {
          const elapsed = now - start;
          const progress = Math.min(elapsed / duration, 1);
          const eased = 1 - Math.pow(1 - progress, 3);
          el.textContent = Math.round(eased * target) + suffix;
          if (progress < 1) requestAnimationFrame(tick);
        };
        requestAnimationFrame(tick);
      });
    }, { threshold: 0.4 });
    counters.forEach((el) => {
      el.dataset.countupInit = 'true';
      observer.observe(el);
    });
  }

  initCountup();
</script>

<!-- ─────────────────────────────────────────────────────────────────────
     Scroll-spy + History API (home only)
     ─────────────────────────────────────────────────────────────────────
     • Clique em nav link correspondente a uma section → smooth scroll +
       history.pushState para a URL da página real (/servicos, etc.)
     • IntersectionObserver ao rolar → history.replaceState + active state
     • Hero visível → URL volta para / e nenhum item fica ativo
     • Respeita prefers-reduced-motion
     • Não afeta pages internas (script só roda na home)
──────────────────────────────────────────────────────────────────────── -->
<script is:inline>
  (function () {
    'use strict';

    // Mapa: id da section na home → href do item de nav
    var SPY_MAP = {
      servicos: '/servicos',
      work: '/portfolio',
      depoimentos: '/depoimentos',
    };

    var spySlugs = Object.keys(SPY_MAP);
    var spyHrefs = Object.values(SPY_MAP);

    // Só rodar quando houver sections com data-spy-section
    var spySections = document.querySelectorAll('[data-spy-section]');
    if (!spySections.length) return;

    var prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // ── Helpers de active state ──────────────────────────────────────────
    function getNavLinks() {
      // Busca tanto no nav desktop quanto mobile
      return document.querySelectorAll('header a');
    }

    function setActive(activeHref) {
      getNavLinks().forEach(function (link) {
        var href = link.getAttribute('href');
        var isMatch = href === activeHref;
        if (isMatch) {
          link.classList.add('hdr-nav-active', 'font-semibold');
          link.classList.remove('font-medium', 'nav-link-inactive');
          link.setAttribute('aria-current', 'page');
        } else if (spyHrefs.indexOf(href) !== -1) {
          // Só reseta os links que fazem parte do spy (não mexe em Blog, Sobre, etc.)
          link.classList.remove('hdr-nav-active', 'font-semibold');
          link.classList.add('font-medium');
          link.removeAttribute('aria-current');
        }
      });
    }

    function clearActive() {
      getNavLinks().forEach(function (link) {
        var href = link.getAttribute('href');
        if (spyHrefs.indexOf(href) !== -1) {
          link.classList.remove('hdr-nav-active', 'font-semibold');
          link.classList.add('font-medium');
          link.removeAttribute('aria-current');
        }
      });
    }

    // ── Interceptar cliques nos links spy do nav ─────────────────────────
    function initClickInterception() {
      getNavLinks().forEach(function (link) {
        var href = link.getAttribute('href');
        if (spyHrefs.indexOf(href) === -1) return;

        // Achar o slug correspondente
        var slug = spySlugs.find(function (s) { return SPY_MAP[s] === href; });
        var section = slug ? document.getElementById(slug) : null;
        if (!section) return;

        link.addEventListener('click', function (e) {
          e.preventDefault();
          section.scrollIntoView({ behavior: prefersReduced ? 'instant' : 'smooth' });
          history.pushState(null, '', href);
          setActive(href);
        });
      });
    }

    // Aguarda o DOM estar pronto (header pode ser renderizado depois)
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initClickInterception);
    } else {
      initClickInterception();
    }

    // ── IntersectionObserver para scroll-spy ─────────────────────────────
    // Rastreia quais sections estão na "zona ativa" (entre 25% e 75% do viewport)
    var activeSections = new Set();

    var observer = new IntersectionObserver(
      function (entries) {
        entries.forEach(function (entry) {
          var slug = entry.target.getAttribute('data-spy-section');
          if (!slug) return;
          if (entry.isIntersecting) {
            activeSections.add(slug);
          } else {
            activeSections.delete(slug);
          }
        });

        // Pegar o primeiro (mais acima) entre as sections ativas
        var activeSlug = spySlugs.find(function (s) { return activeSections.has(s); });

        if (activeSlug) {
          var href = SPY_MAP[activeSlug];
          history.replaceState(null, '', href);
          setActive(href);
        } else {
          // Nenhuma section na zona — provavelmente na Hero ou no rodapé
          history.replaceState(null, '', '/');
          clearActive();
        }
      },
      {
        // Zona de ativação: ignora os 25% de cima e os 35% de baixo do viewport
        // (o 25% superior lida com o header fixo; o 35% inferior evita ativar
        //  a próxima section cedo demais ao rolar para baixo)
        rootMargin: '-25% 0px -35% 0px',
        threshold: 0,
      }
    );

    spySections.forEach(function (section) {
      observer.observe(section);
    });

    // ── Botão Voltar/Avançar do browser ──────────────────────────────────
    window.addEventListener('popstate', function () {
      var path = window.location.pathname;
      var matchingHref = spyHrefs.find(function (h) { return h === path; });
      if (matchingHref) {
        var slug = spySlugs.find(function (s) { return SPY_MAP[s] === matchingHref; });
        var section = slug ? document.getElementById(slug) : null;
        if (section) {
          section.scrollIntoView({ behavior: prefersReduced ? 'instant' : 'smooth' });
          setActive(matchingHref);
        }
      } else {
        clearActive();
      }
    });
  })();
</script>

</LandingLayout>
