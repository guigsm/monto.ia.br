---
import { Image } from 'astro:assets';
import LandingLayout from '@/layouts/LandingLayout.astro';
import { Hero } from '@/components/hero';
import Button from '@/components/ui/form/Button/Button.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import BlogCard from '@/components/blog/BlogCard.astro';
import LighthouseScores from '@/components/landing/LighthouseScores.astro';
import LetterGlitchBand from '@/components/patterns/LetterGlitchBand.astro';
import { getCollection } from 'astro:content';
import siteConfig from '@/config/site.config';

const projectItems = await getCollection('projects');
const featuredProjects = projectItems
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 4);

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => {
    if (a.data.featured !== b.data.featured) return a.data.featured ? -1 : 1;
    return b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf();
  })
  .slice(0, 3);
---

<LandingLayout
  title="Monto IA — Sites, SEO, Ads e Automações com IA na medida"
  description="A Monto IA cria sites profissionais com bom SEO, Ads, blog com produção por IA, boas práticas (Lighthouse) e IA conversacional na medida — tudo integrado para o seu negócio crescer."
  image="/og-default.svg"
  includePersonSchema={false}
  includeProfessionalServiceSchema={true}
>
  <!-- Hero -->
  <Hero layout="centered" size="xl" class="hero-dark-gradient" showScrollIndicator>
    <Badge slot="badge" variant="brand" pill pulse class="dark:text-brand-200">Disponíveis para novos projetos</Badge>

    <h1 slot="title" class="!text-[clamp(2rem,11.2vw,3rem)] sm:!text-5xl md:!text-6xl lg:!text-7xl">
      <span class="text-brand-600 dark:text-foreground [-webkit-text-fill-color:currentColor]">Site bonito é fácil.</span><br />
      <span class="text-brand-600 dark:text-foreground [-webkit-text-fill-color:currentColor]">O resultado vem da</span><br class="md:hidden" /><span class="text-brand-500"> integração.</span>
    </h1>

    <p slot="description">
      Site profissional, bom SEO, campanhas de Ads, blog com produção por IA, boas práticas de performance (Lighthouse) e IA conversacional quando faz sentido — tudo conectado, na medida certa do seu negócio. IA na medida, não só por ter.
    </p>

   <Fragment slot="actions">
      <Button size="lg" href="/contato">
        Quero um projeto
        <Icon name="arrow-right" size="sm" />
      </Button>
      <Button size="lg" variant="outline" href="/portfolio">
        <Icon name="layers" size="sm" />
        Ver portfólio
        <Icon name="arrow-right" size="sm" />
      </Button>
    </Fragment>
  </Hero>

  <!-- Services Section — data-spy-section para o scroll-spy da home -->
  <section id="servicos" data-spy-section="servicos" class="relative z-10 py-[var(--space-section-md)] bg-background-secondary border-t border-border">
    <div class="mx-auto max-w-6xl px-6 flex flex-col gap-8">
      <div class="flex flex-col items-center gap-4 text-center" data-reveal>
        <div class="flex flex-col items-center gap-6">
          <Badge variant="brand" pill>O que fazemos</Badge>
          <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
            Tudo o que um negócio digital precisa, integrado
          </h2>
        </div>
        <p class="text-lg text-foreground-muted max-w-2xl mx-auto">
          O site é o ponto de partida — o resto é o que faz ele gerar resultado.
        </p>
      </div>

      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
        <!-- Sites profissionais -->
        <Card hover data-reveal>
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="layout" size="sm" />
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-semibold text-foreground">Sites profissionais</h3>
              <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                Design moderno, rápido e responsivo, com a identidade da sua marca — construído sobre uma base técnica sólida desde o primeiro dia.
              </p>
            </div>
          </div>
        </Card>

        <!-- SEO & Ads -->
        <Card hover data-reveal data-reveal-delay="1">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="search" size="sm" />
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-semibold text-foreground">SEO, Ads e Performance</h3>
              <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                SEO técnico, boas práticas (Lighthouse) e campanhas de Ads bem configuradas — para o site aparecer e converter, não só existir.
              </p>
            </div>
          </div>
        </Card>

        <!-- Blog com IA -->
        <Card hover data-reveal data-reveal-delay="2">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="pen-tool" size="sm" />
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-semibold text-foreground">Blog com produção por IA</h3>
              <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                Conteúdo novo no ar com frequência, com apoio de IA na produção e revisão humana — alimentando SEO sem virar trabalho extra para você.
              </p>
            </div>
          </div>
        </Card>

        <!-- Automação & IA -->
        <Card hover data-reveal data-reveal-delay="3">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="workflow" size="sm" />
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-semibold text-foreground">Automações & IA conversacional</h3>
              <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                Integrações com N8N e IA conversacional no WhatsApp ou no site quando isso resolve um problema real — na medida do seu negócio, não por modismo.
              </p>
