---
import BlogLayout from '@/layouts/BlogLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  // 1. Busca a coleção e filtra apenas os posts que são em português ('pt')
  // Também mantém a regra do template de ignorar rascunhos (drafts) em produção
  const posts = await getCollection('blog', ({ data }) => {
    return String(data.locale) === 'pt' && (import.meta.env.PROD ? data.draft !== true : true);
  });

  // 2. Mapeia as rotas removendo o prefixo 'pt/' do ID para gerar a URL limpa
  return posts.map((post) => ({
    params: { slug: post.id.replace('pt/', '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
---

<BlogLayout
  title={post.data.title}
  description={post.data.description}
  publishedAt={post.data.publishedAt}
  updatedAt={post.data.updatedAt}
  author={post.data.author}
  image={post.data.image}
  imageAlt={post.data.imageAlt}
  svgSlug={post.data.svgSlug}
  tags={post.data.tags}
  slug={post.id}
  headings={headings}
  toc={post.data.toc}
  comments={post.data.comments}
>
  <Content />
</BlogLayout>
