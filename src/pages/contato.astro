---
/**
 * Página de Contato
 * URL: /contato
 */
import PageLayout from '@/layouts/PageLayout.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import { Hero } from '@/components/hero';
import ContactForm from '@/components/patterns/ContactForm.astro';
import siteConfig from '@/config/site.config';
import { resolveSocialLinks } from '@/lib/utils';
import contactContent from '@/content/pages/contact.json';

const locale = 'pt-br';

const content = {
  badge:              contactContent.ptBadge,
  heroTitle:          contactContent.ptHeroTitle,
  heroTitleBrand:     contactContent.ptHeroTitleBrand,
  heroDescription:    contactContent.ptHeroDescription,
  formTitle:          contactContent.ptFormTitle,
  channelsTitle:      contactContent.ptChannelsTitle,
  channelsDescription:contactContent.ptChannelsDescription,
  locationNote:       contactContent.ptLocationNote,
};

const socialLinks = resolveSocialLinks(siteConfig.socialLinks);

/** Format +5511967053115 → (11) 96705-3115 */
function formatBrPhone(raw: string): string {
  const d = raw.replace(/\D/g, '');
  if (d.startsWith('55') && d.length >= 12) {
    const local = d.slice(2);
    if (local.length === 11) return `(${local.slice(0,2)}) ${local.slice(2,7)}-${local.slice(7)}`;
    if (local.length === 10) return `(${local.slice(0,2)}) ${local.slice(2,6)}-${local.slice(6)}`;
  }
  return `+${d}`;
}

const whatsappDisplay = siteConfig.whatsapp ? formatBrPhone(siteConfig.whatsapp) : '';

// Order: WhatsApp · Instagram · LinkedIn · Google Place
const channels = [
  ...(siteConfig.whatsapp ? [{
    icon:     'simple-icons:whatsapp',
    label:    'WhatsApp',
    value:    whatsappDisplay,
    href:     `https://wa.me/${siteConfig.whatsapp}`,
    external: true,
    pulse:    true,
  }] : []),
  ...socialLinks.map((link) => ({
    icon:     link.icon,
    label:    link.key === 'google-place' ? 'Google Meu Negócio' : link.label,
    value:    link.key === 'google-place' ? 'Confira nossos reviews' : link.href.replace(/^https?:\/\/(www\.)?/, ''),
    href:     link.href,
    external: true,
    pulse:    false,
  })),
];
---

<PageLayout
  title="Contato — Monto IA"
  description={`${content.heroTitle} ${content.heroTitleBrand}. ${content.heroDescription}`}
  eagerReveal
>
  <Hero layout="centered" size="sm">
    <Badge slot="badge" variant="brand" pill>
      <Icon name="mail" size="sm" />
      {content.badge}
    </Badge>

    <h1 slot="title">
      {content.heroTitle} <span class="text-brand-500">{content.heroTitleBrand}</span>
    </h1>

    <p slot="description">
      {content.heroDescription}
    </p>
  </Hero>

  <!-- Seção principal -->
  <section class="py-[var(--space-section-md)] bg-background-secondary border-t border-border">
    <div class="mx-auto max-w-5xl px-6">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-10 lg:gap-16 items-stretch">

        <!-- Coluna esquerda: formulário -->
        <div class="lg:col-span-3 h-full" data-reveal="right">
          <Card padding="md" class="h-full flex flex-col justify-center !py-4 lg:!py-5">
            <h2 class="font-display text-xl font-bold text-foreground mb-4">{content.formTitle}</h2>
            <ContactForm locale={locale} />
          </Card>
        </div>

        <!-- Coluna direita: canais e localização -->
        <div class="lg:col-span-2 space-y-4" data-reveal="left" data-reveal-delay="1">
          <div>
            <h2 class="font-display text-lg font-bold text-foreground mb-1">{content.channelsTitle}</h2>
            <p class="text-sm text-foreground-muted">{content.channelsDescription}</p>
          </div>

          <div class="space-y-2">
            {channels.map((ch) => (
              <a
                href={ch.href}
                {...ch.external ? { target: '_blank', rel: 'noopener noreferrer' } : {}}
                class="block group"
              >
                <Card
                  hover
                  padding="sm"
                  class={ch.pulse ? 'h-full channel-wp-pulse' : 'h-full channel-shimmer'}
                >
                  <div class="flex items-center gap-3">
                    <div class="w-10 h-10 shrink-0 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500">
                      <Icon name={ch.icon} size="sm" />
                    </div>
                    <div class="min-w-0 flex-1">
                      <p class="font-semibold text-sm text-foreground">{ch.label}</p>
                      <p class="text-xs text-foreground-muted truncate">{ch.value}</p>
                    </div>
                    <Icon name="arrow-up-right" size="sm" class="text-foreground-muted group-hover:text-brand-500 transition-colors shrink-0" />
                  </div>
                </Card>
              </a>
            ))}

            {siteConfig.calendly && (
              <a
                href={siteConfig.calendly}
                target="_blank"
                rel="noopener noreferrer"
                class="block group"
              >
                <Card
                  hover
                  padding="sm"
                  class="h-full channel-shimmer bg-gradient-to-br from-brand-500/10 to-brand-600/5 border-brand-500/25"
                >
                  <div class="flex items-center gap-3">
                    <div class="w-10 h-10 shrink-0 rounded-xl bg-brand-500 flex items-center justify-center text-white">
                      <Icon name="simple-icons:calendly" size="sm" />
                    </div>
                    <div class="min-w-0 flex-1">
                      <p class="font-semibold text-sm text-foreground">Agende uma reunião</p>
                      <p class="text-xs text-foreground-muted">30 min · Google Meet</p>
                    </div>
                    <Icon name="arrow-up-right" size="sm" class="text-foreground-muted group-hover:text-brand-500 transition-colors shrink-0" />
                  </div>
                </Card>
              </a>
            )}
          </div>

        </div>

      </div>
    </div>
  </section>
</PageLayout>

<style is:global>
  @keyframes wp-pulse {
    0%, 100% { box-shadow: 0 0 0 0 color-mix(in oklch, var(--brand-500) 0%, transparent); }
    50%       { box-shadow: 0 0 0 3px color-mix(in oklch, var(--brand-500) 20%, transparent),
                            0 0 10px color-mix(in oklch, var(--brand-500) 10%, transparent); }
  }
  /* ─── Shimmer: spotlight via @property for seamless loop ─── */
  @property --shimmer-x {
    syntax: '<percentage>';
    initial-value: -30%;
    inherits: false;
  }
  @keyframes channel-shimmer {
    from { --shimmer-x: -30%; }
    to   { --shimmer-x: 130%; }
  }

  /* WhatsApp: always pulse */
  .channel-wp-pulse {
    animation: wp-pulse 2.5s ease-in-out infinite;
  }

  /* All channel cards: position:relative so ::before can be absolute */
  .channel-shimmer,
  .channel-wp-pulse {
    position: relative;
    overflow: hidden;
  }

  /* Shimmer pseudo-element: opacity transition = smooth fade-in/out */
  .channel-shimmer::before,
  .channel-wp-pulse::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.5s ease;
    background-image: linear-gradient(
      105deg,
      transparent 0%,
      transparent calc(var(--shimmer-x) - 25%),
      color-mix(in oklch, var(--brand-600) 3%, transparent) calc(var(--shimmer-x) - 12%),
      color-mix(in oklch, var(--brand-300) 7%, transparent) var(--shimmer-x),
      color-mix(in oklch, var(--brand-600) 3%, transparent) calc(var(--shimmer-x) + 12%),
      transparent calc(var(--shimmer-x) + 25%),
      transparent 100%
    );
  }

  /* On hover: fade in shimmer + start animation */
  .group:hover .channel-shimmer::before,
  .group:hover .channel-wp-pulse::before {
    opacity: 1;
    animation: channel-shimmer 1.8s linear infinite;
  }
</style>
