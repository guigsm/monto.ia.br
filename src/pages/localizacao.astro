---
/**
 * Localização page
 * URL: /localizacao
 * EN equivalent: /en/location (pendente)
 */
import PageLayout from '@/layouts/PageLayout.astro';
import { Hero } from '@/components/hero';
import Button from '@/components/ui/form/Button/Button.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import siteConfig from '@/config/site.config';
import d from '../content/pages/localizacao.json';
---

<PageLayout
  title={`${d.ptTitle} — ${siteConfig.name}`}
  description={d.ptDescription}
  noindex={d.noIndex}
>
  <Hero layout="centered" size="sm">
    <Badge slot="badge" variant="brand" pill>
      <Icon name="map-pin" size="sm" />
      Onde estamos
    </Badge>
    <h1 slot="title">{d.ptHeroTitle}</h1>
    <p slot="description">{d.ptHeroDescription}</p>
  </Hero>

  <!-- Detalhes de localização -->
  <section class="py-[var(--space-section-md)] bg-background-secondary border-t border-border">
    <div class="mx-auto max-w-4xl px-6 flex flex-col gap-8">
      <div class="grid gap-6 md:grid-cols-2">
        <!-- Endereço -->
        {d.ptAddress && (
          <Card variant="elevated" padding="lg" data-reveal>
            <div class="flex items-start gap-4">
              <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
                <Icon name="map-pin" size="md" />
              </div>
              <div>
                <h2 class="text-base font-semibold text-foreground mb-1">Localização</h2>
                <p class="text-sm text-foreground-muted leading-relaxed">{d.ptAddress}</p>
              </div>
            </div>
          </Card>
        )}

        <!-- Área de atendimento -->
        {d.ptServiceArea && (
          <Card variant="elevated" padding="lg" data-reveal data-reveal-delay="1">
            <div class="flex items-start gap-4">
              <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
                <Icon name="globe" size="md" />
              </div>
              <div>
                <h2 class="text-base font-semibold text-foreground mb-1">Área de atendimento</h2>
                <p class="text-sm text-foreground-muted leading-relaxed">{d.ptServiceArea}</p>
              </div>
            </div>
          </Card>
        )}

        <!-- Horário -->
        {d.ptHours && (
          <Card variant="elevated" padding="lg" data-reveal data-reveal-delay="2">
            <div class="flex items-start gap-4">
              <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
                <Icon name="clock" size="md" />
              </div>
              <div>
                <h2 class="text-base font-semibold text-foreground mb-1">Horário de atendimento</h2>
                <p class="text-sm text-foreground-muted leading-relaxed">{d.ptHours}</p>
              </div>
            </div>
          </Card>
        )}
      </div>

      <!-- Mapa embed (opcional) -->
      {d.ptMapEmbedUrl && (
        <div class="rounded-xl overflow-hidden border border-border" data-reveal>
          <iframe
            src={d.ptMapEmbedUrl}
            width="100%"
            height="400"
            class="border-0 block"
            allowfullscreen
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        </div>
      )}

      <div class="text-center" data-reveal>
        <Button size="lg" href="/contato">
          Falar com a Monto IA
          <Icon name="arrow-right" size="sm" />
        </Button>
      </div>
    </div>
  </section>
</PageLayout>
