---
import PageLayout from '@/layouts/PageLayout.astro';
import { unified } from 'unified';
import remarkParse from 'remark-parse';
import remarkGfm from 'remark-gfm';
import remarkRehype from 'remark-rehype';
import rehypeStringify from 'rehype-stringify';
import privacyData from '../../content/pages/privacy-policy.json';

const enHtml = String(
  await unified()
    .use(remarkParse)
    .use(remarkGfm)
    .use(remarkRehype)
    .use(rehypeStringify)
    .process(privacyData.enContent || '')
);
---

<PageLayout
  title={privacyData.enTitle}
  description={privacyData.enDescription}
  noindex={privacyData.noIndex}
>
  <div class="mx-auto max-w-3xl px-6 py-16 md:py-24">
    <div class="mb-10">
      <a
        href="/en"
        class="inline-flex items-center gap-1.5 text-sm text-foreground-muted hover:text-foreground transition-colors"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M19 12H5M12 19l-7-7 7-7"/>
        </svg>
        Home
      </a>
    </div>

    <h1 class="text-3xl font-bold tracking-tight text-foreground mb-8">{privacyData.enTitle}</h1>

    <article class="prose prose-lg max-w-none" set:html={enHtml} />

    <div class="mt-12 pt-8 border-t border-border">
      <p class="text-sm text-foreground-muted">
        Versão em português: <a href="/politica-de-privacidade" class="underline hover:text-foreground transition-colors">Política de Privacidade</a>
      </p>
    </div>
  </div>
</PageLayout>
