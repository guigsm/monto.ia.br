---
import { getCollection, render } from 'astro:content';
import PageLayout from '@/layouts/PageLayout.astro';

const allPages = await getCollection('customPages');
const entry = allPages.find(e => e.id.replace(/\.mdx?$/, '') === 'privacy-policy');
if (!entry) return Astro.redirect('/en/404');

const { Content } = await render(entry);
---

<PageLayout
  title={entry.data.title}
  description={entry.data.description}
  noindex={true}
>
  <div class="mx-auto max-w-3xl px-6 py-16 md:py-24">
    <div class="mb-10">
      <a
        href="/en"
        class="inline-flex items-center gap-1.5 text-sm text-foreground-muted hover:text-foreground transition-colors"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M19 12H5M12 19l-7-7 7-7"/>
        </svg>
        Home
      </a>
    </div>

    <article class="prose prose-lg max-w-none">
      <Content />
    </article>

    <div class="mt-12 pt-8 border-t border-border">
      <p class="text-sm text-foreground-muted">
        Versão em português: <a href="/politica-de-privacidade" class="underline hover:text-foreground transition-colors">Política de Privacidade</a>
      </p>
    </div>
  </div>
</PageLayout>
