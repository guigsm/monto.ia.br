---
/**
 * 404 page — English
 *
 * When `i18nConfig.blog.translated === false` (see `src/config/i18n.config.ts`),
 * the blog only exists at the Portuguese routes (`/blog`, `/blog/<slug>`,
 * `/blog/page/<n>`, `/blog/tag/<tag>`). Any deep link under `/en/blog/**`
 * therefore 404s here. Instead of showing a generic "not found" message for
 * those URLs, a small inline script detects `/blog` in the current path and
 * swaps in a "blog available in Portuguese" message with a link back to the
 * PT blog and an "Open in Google Translate" shortcut for that exact page.
 *
 * When `translated === true`, `/en/blog/**` routes exist for real (see
 * `src/pages/en/blog/`), so a 404 there is a genuine not-found — the
 * fallback script is skipped entirely.
 */
import PageLayout from '@/layouts/PageLayout.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import { Hero } from '@/components/hero';
import { HOME_PATH } from '@/config/nav.config'; // TEMP-HOME-OVERRIDE: ver nav.config.ts
import { getLocaleName, isBlogTranslated, localizedPath, t } from '@/i18n';

const translated = isBlogTranslated();
const blogHref = translated ? '/en/blog' : '/blog';

const recoveryLinks = [
  {
    icon: 'layers',
    title: 'Projects',
    description: 'Selected work and case studies.',
    href: '/projects',
  },
  {
    icon: 'book',
    title: 'Blog',
    description: 'Notes on design, code, and the craft.',
    href: blogHref,
  },
  {
    icon: 'mail',
    title: 'Contact',
    description: 'Start a conversation about your project.',
    href: '/contact',
  },
];
---

<PageLayout
  title="Page not found — Astro Rocket"
  description="This page has moved, been removed, or never existed in the first place."
  noindex
  eagerReveal
>
  <div id="default-404-content">
    <Hero layout="centered" size="sm">
      <Badge slot="badge" variant="brand" pill>
        <Icon name="compass" size="sm" />
        404 — page not found
      </Badge>

      <h1 slot="title">
        Page not <span class="text-brand-500">found.</span>
      </h1>

      <p slot="description">
        This page has moved, been removed, or never existed in the first place. Let's get you back on track.
      </p>

      <div slot="actions" class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <Button href={localizedPath(HOME_PATH, 'en')} size="lg">
          <Icon name="arrow-left" size="sm" />
          Back to home
        </Button>
        <Button href={blogHref} variant="outline" size="lg">
          Browse the blog
          <Icon name="arrow-right" size="sm" />
        </Button>
      </div>
    </Hero>

    <!-- Recovery Section -->
    <section class="py-[var(--space-section-md)] bg-background-secondary border-t border-border">
      <div class="mx-auto max-w-6xl px-6">
        <div class="mb-8 text-center" data-reveal>
          <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
            Try one of these instead
          </h2>
        </div>

        <div class="grid gap-6 md:grid-cols-3">
          {recoveryLinks.map((link, i) => (
            <Card hover href={link.href} class="group" data-reveal data-reveal-delay={i}>
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
                  <Icon name={link.icon} size="sm" />
                </div>
                <div class="flex-1 min-w-0">
                  <h3 class="text-base font-semibold text-foreground">{link.title}</h3>
                  <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                    {link.description}
                  </p>
                </div>
                <Icon name="arrow-up-right" size="sm" class="text-foreground-muted group-hover:text-brand-500 transition-colors shrink-0" />
              </div>
            </Card>
          ))}
        </div>
      </div>
    </section>
  </div>

  {!translated && (
    <div id="blog-not-translated-fallback" class="hidden">
      <Hero layout="centered" size="sm">
        <Badge slot="badge" variant="brand" pill>
          <Icon name="languages" size="sm" />
          {t('blog.title', 'en')}
        </Badge>

        <h1 slot="title">{t('blog.notTranslated.title', 'en')}</h1>

        <p slot="description">
          {t('blog.notTranslated.description', 'en', { language: getLocaleName('en') })}
        </p>

        <div slot="actions" class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <Button id="blog-fallback-back-link" href="/blog" size="lg">
            <Icon name="arrow-left" size="sm" />
            {t('blog.notTranslated.backToBlog', 'en')}
          </Button>
          <Button id="blog-fallback-translate-link" href="https://translate.google.com" target="_blank" rel="noopener noreferrer" variant="outline" size="lg">
            <Icon name="languages" size="sm" />
            {t('blog.notTranslated.openInGoogleTranslate', 'en')}
            <Icon name="external-link" size="sm" />
          </Button>
        </div>
      </Hero>
    </div>

    <script>
      // Detect deep links into the (Portuguese-only) blog and replace the
      // generic 404 with a "blog available in Portuguese" message that links
      // back to the equivalent PT page and offers Google Translate for it.
      const path = window.location.pathname;

      if (path.includes('/blog')) {
        const fallback = document.getElementById('blog-not-translated-fallback');
        const defaultContent = document.getElementById('default-404-content');

        if (fallback && defaultContent) {
          defaultContent.classList.add('hidden');
          fallback.classList.remove('hidden');

          // Strip the `/en` locale prefix to get the equivalent PT path
          // (e.g. `/en/blog/my-post` -> `/blog/my-post`).
          const ptPath = path.replace(/^\/en(?=\/|$)/, '') || '/blog';
          const ptUrl = `${window.location.origin}${ptPath}`;

          const backLink = document.getElementById('blog-fallback-back-link');
          if (backLink instanceof HTMLAnchorElement) {
            backLink.href = ptPath;
          }

          const translateLink = document.getElementById('blog-fallback-translate-link');
          if (translateLink instanceof HTMLAnchorElement) {
            translateLink.href = `https://translate.google.com/translate?sl=pt&tl=en&u=${encodeURIComponent(ptUrl)}`;
          }
        }
      }
    </script>
  )}
</PageLayout>
