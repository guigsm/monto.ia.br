# =====================================================
# Monto API — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o .env no repositório
# =====================================================

# Ambiente: production | development
APP_ENV=production

# Permitir chamadas de localhost (útil em desenvolvimento)
ALLOW_LOCALHOST=false

# ---- SMTP ----
SMTP_HOST=smtp.seuprovedor.com
SMTP_PORT=587
SMTP_SECURE=tls
SMTP_USER=seu@email.com
SMTP_PASS=suasenha
SMTP_FROM=noreply@seudominio.com
SMTP_FROM_NAME=API de Contato

# ---- Arquivos ----
# Caminho absoluto para o arquivo de tokens (padrão: data/tokens.json relativo à api/)
# TOKENS_FILE=/caminho/absoluto/tokens.json

# ---- Logs ----
LOG_ENABLED=true
# LOG_FILE=/caminho/absoluto/api.log
