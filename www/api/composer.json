{
    "name": "monto/api",
    "description": "API de serviços Monto — Formail e gerenciamento de tokens",
    "type": "project",
    "require": {
        "php": ">=8.3",
        "phpmailer/phpmailer": "^6.9",
        "vlucas/phpdotenv": "^5.6"
    },
    "autoload": {
        "psr-4": {
            "MontoAPI\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
